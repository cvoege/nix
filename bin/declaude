#!/usr/bin/env bash

set -euo pipefail

# declaude — for when the AI tries to claim credit over things you did
# by sneaking in a "co-author" when it didn't do anything.

die() { echo "declaude: $*" >&2; exit 1; }
info() { echo "• $*" >&2; }

# --- figure out where the branch starts -------------------------------------
branch=$(git symbolic-ref --quiet --short HEAD) \
  || die "detached HEAD; checkout a branch first."

parent=$(git stack parent 2>/dev/null || true)
if [[ -z "$parent" || "$parent" == "(no parent recorded"* ]]; then
  base=$(git stack trunk) || die "couldn't determine trunk."
else
  base="$parent"
fi

git rev-parse --verify --quiet "$base^{commit}" >/dev/null \
  || die "base '$base' is not a valid commit."

[[ "$branch" != "$base" ]] \
  || die "'$branch' is the base ('$base'); nothing above it to scrub."

count=$(git rev-list --count "$base..HEAD")
[[ "$count" -gt 0 ]] \
  || die "no commits on '$branch' beyond '$base'; nothing to scrub."

info "scrubbing $count commit(s) on '$branch' (base: '$base')…"

# --- your identity, for reclaiming AI-authored commits ----------------------
ME_NAME=$(git config user.name || true)
ME_EMAIL=$(git config user.email || true)
[[ -n "$ME_NAME" && -n "$ME_EMAIL" ]] \
  || die "git user.name / user.email not set; can't reassign authorship."
export ME_NAME ME_EMAIL

# --- rewrite authorship + commit messages -----------------------------------
export FILTER_BRANCH_SQUELCH_WARNING=1
git filter-branch --force \
  --env-filter '
    bot="@anthropic\.com|@cursor\.(com|sh)|(^| )claude( |$)|(^| )cursor( agent)?( |$)|cursor\[bot\]"
    if printf "%s" "$GIT_AUTHOR_EMAIL $GIT_AUTHOR_NAME" | grep -qiE "$bot"; then
      export GIT_AUTHOR_NAME="$ME_NAME" GIT_AUTHOR_EMAIL="$ME_EMAIL"
    fi
    if printf "%s" "$GIT_COMMITTER_EMAIL $GIT_COMMITTER_NAME" | grep -qiE "$bot"; then
      export GIT_COMMITTER_NAME="$ME_NAME" GIT_COMMITTER_EMAIL="$ME_EMAIL"
    fi
  ' \
  --msg-filter '
  perl -0777 -pe "
    s/^.*<[^>]*\@(anthropic\.com|cursor\.(com|sh))>.*\n//gim;
    s/^[ \t]*Co-authored-by:.*(claude|cursor).*\n//gim;
    s/^.*Generated with \[?(Claude Code|Cursor).*\n//gim;
    s/^[ \t]*🤖.*\n//gm;
    s/\n{2,}\z/\n/;
    s/^\n+//;
  "
' -- "$base..HEAD" >/dev/null

# --- drop the filter-branch backup refs -------------------------------------
git for-each-ref --format='%(refname)' refs/original/ \
  | while read -r ref; do git update-ref -d "$ref"; done

info "done — commit SHAs on '$branch' have been rewritten."
