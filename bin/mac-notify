#!/usr/bin/env bash
#
# mac-notify — post a macOS Notification Center banner from the command line.
#
# A thin, reusable wrapper around osascript's `display notification`, safe to
# call with arbitrary text: the message/title/subtitle are passed to AppleScript
# as env vars (via `system attribute`) rather than interpolated into the script
# source, so quotes/backslashes in the text can't break or inject AppleScript.
#
# Usage:
#   mac-notify <message> [title] [subtitle]
#   mac-notify -s <sound> <message> [title] [subtitle]
#   echo "message" | mac-notify            # message from stdin if no args
#
# Options:
#   -s, --sound <name>   Notification sound (e.g. Glass, Ping, Hero, Submarine).
#                        Default: Glass. Pass "" or "none" for a silent banner.
#   -t, --title <text>   Title (overrides positional title).
#   -h, --help           Show this help.
#
# Exits 0 on success. If not on macOS / osascript is missing, prints a warning
# to stderr and exits 0 anyway — a missing notification should never fail a
# caller's pipeline.

set -euo pipefail

sound="Glass"
title="notification"
subtitle=""
message=""

usage() {
  sed -n '3,26p' "$0" | sed 's/^# \{0,1\}//' >&2
}

# --- args -----------------------------------------------------------------
positional=()
while [ $# -gt 0 ]; do
  case "$1" in
    -s|--sound)  sound="${2:-}"; shift 2 ;;
    -t|--title)  title="${2:-}"; shift 2 ;;
    -h|--help)   usage; exit 0 ;;
    --)          shift; while [ $# -gt 0 ]; do positional+=("$1"); shift; done; break ;;
    -*)          echo "mac-notify: unknown option: $1" >&2; usage; exit 1 ;;
    *)           positional+=("$1"); shift ;;
  esac
done

[ "${#positional[@]}" -ge 1 ] && message="${positional[0]}"
[ "${#positional[@]}" -ge 2 ] && title="${positional[1]}"
[ "${#positional[@]}" -ge 3 ] && subtitle="${positional[2]}"

# Fall back to stdin when no message was given on the command line.
if [ -z "$message" ] && [ ! -t 0 ]; then
  message="$(cat)"
fi

if [ -z "$message" ]; then
  echo "mac-notify: no message" >&2
  usage
  exit 1
fi

if ! command -v osascript >/dev/null 2>&1; then
  echo "mac-notify: osascript not found (not macOS?); skipping: $message" >&2
  exit 0
fi

# Pass text through the environment so AppleScript reads it with `system
# attribute` — never string-interpolated into the script, so no escaping or
# injection concerns regardless of what the text contains.
MN_MSG="$message" MN_TITLE="$title" MN_SUB="$subtitle" MN_SOUND="$sound" \
osascript \
  -e 'set msg to (system attribute "MN_MSG")' \
  -e 'set ttl to (system attribute "MN_TITLE")' \
  -e 'set sub to (system attribute "MN_SUB")' \
  -e 'set snd to (system attribute "MN_SOUND")' \
  -e 'if sub is not "" then' \
  -e '  if snd is not "" and snd is not "none" then' \
  -e '    display notification msg with title ttl subtitle sub sound name snd' \
  -e '  else' \
  -e '    display notification msg with title ttl subtitle sub' \
  -e '  end if' \
  -e 'else' \
  -e '  if snd is not "" and snd is not "none" then' \
  -e '    display notification msg with title ttl sound name snd' \
  -e '  else' \
  -e '    display notification msg with title ttl' \
  -e '  end if' \
  -e 'end if' \
  2>/dev/null || echo "mac-notify: failed to post notification: $message" >&2
