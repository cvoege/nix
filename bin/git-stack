#!/usr/bin/env bash
# git-stack — manage PR-stack metadata (parent pointers) and view the stack.
#
# Subcommands:
#   git stack                       show the stack you're currently on (a tree)
#   git stack list-stacks           show every tracked stack (all trees on trunk)
#   git stack prs                   show the stack, each branch labelled with its GitHub PR
#   git stack prs list              flat one-branch-per-line PR list (LLM-friendly)
#   git stack list                  print "<branch>\t<parent>" bottom->top (for scripts)
#   git stack checkout              pick a branch in the current stack (or create a
#                                   new one on the end) from an interactive selector
#   git stack infer [--dry-run]     reconstruct the stack of the current branch from
#                                   its GitHub PRs: trace each PR's base branch down
#                                   to trunk and up to the leaves, fetch every branch,
#                                   and record the parent pointers
#   git stack parent [<parent>]     show, or set, the current branch's parent
#   git stack parent --unset        stop tracking the current branch, moving its
#                                   children onto the current branch's parent
#   git stack new <name> [<parent>] create a branch and record its parent
#                                   (parent defaults to the current branch)
#   git stack remove <name>         delete a branch and re-parent its children onto its parent
#   git stack collapse              flatten a linear stack into its root branch
#                                   (ff-merge each branch down, push, remove the leaf)
#   git stack restack               rebase the whole stack into one clean linear
#                                   history (fetch, rebase bottom->top, force-push);
#                                   --continue / --abort to resume or undo a conflict
#   git stack sync                  drop merged branches from the stack (reparenting
#                                   their children) then restack the remainder
#   git stack trunk [<branch>]      show, or set, the trunk (default: origin HEAD)

set -euo pipefail

# ---- trunk ---------------------------------------------------------------

stack_trunk() {
  local t
  t=$(git config --get stack.trunk || true)
  if [[ -n "$t" ]]; then echo "$t"; return 0; fi
  # origin's default branch, e.g. refs/remotes/origin/HEAD -> origin/trunk
  t=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)
  if [[ -n "$t" ]]; then echo "${t#origin/}"; return 0; fi
  local c
  for c in trunk main master; do
    if git show-ref --verify --quiet "refs/heads/$c"; then echo "$c"; return 0; fi
  done
  echo "main"
}

# ---- branch / parent metadata -------------------------------------------

branch_exists() { git show-ref --verify --quiet "refs/heads/$1"; }

stack_parent() { git config --get "branch.$1.stackParent" || true; }

stack_set_parent() { git config "branch.$1.stackParent" "$2"; }

stack_unset_parent() { git config --unset "branch.$1.stackParent" 2>/dev/null || true; }

current_branch() { git symbolic-ref --quiet --short HEAD 2>/dev/null || true; }

# All local branches that have a recorded parent.
# git canonicalises config keys to lowercase (branch.<name>.stackparent), but
# preserves the case of the <name> subsection; each line is "<key> <value>".
stack_tracked_branches() {
  git config --get-regexp '^branch\..*\.stackParent$' 2>/dev/null \
    | sed -E 's/^branch\.(.*)\.stackparent .*$/\1/' || true
}

# Direct children of a branch (tracked branches whose parent == $1).
stack_children() {
  local target="$1" b
  while read -r b; do
    [[ -z "$b" ]] && continue
    [[ "$(stack_parent "$b")" == "$target" ]] && echo "$b"
  done < <(stack_tracked_branches)
}

# Walk parent pointers from $1 up to the root branch (the one whose parent is
# the trunk). Errors if a branch in the chain has no parent recorded.
stack_root() {
  local b="$1" trunk p guard=0
  trunk=$(stack_trunk)
  [[ "$b" == "$trunk" ]] && { echo "ERR:on-trunk"; return 1; }
  while :; do
    p=$(stack_parent "$b")
    if [[ -z "$p" ]]; then echo "ERR:no-parent:$b"; return 1; fi
    [[ "$p" == "$trunk" ]] && { echo "$b"; return 0; }
    b="$p"
    guard=$((guard + 1)); [[ $guard -gt 1000 ]] && { echo "ERR:cycle"; return 1; }
  done
}

# Topological list (parents before children) of every branch in the stack that
# $1 belongs to. Output: one branch name per line, trunk excluded.
stack_collect() {
  local start="$1" root
  root=$(stack_root "$start") || { echo "$root"; return 1; }
  # BFS from root over the children map; tree => parents always precede children.
  local queue=("$root") b child
  while [[ ${#queue[@]} -gt 0 ]]; do
    b="${queue[0]}"; queue=("${queue[@]:1}")
    echo "$b"
    while read -r child; do
      [[ -n "$child" ]] && queue+=("$child")
    done < <(stack_children "$b")
  done
}

# Die with a friendly message if $1 is an ERR:* sentinel from stack_root /
# stack_collect; a no-op otherwise. Call it from the CONSUMER side of a
# `while read … < <(stack_collect)` loop, never the producer: die runs `exit`,
# which terminates only the current shell, not a process-substitution subshell.
stack_check_err() {
  case "$1" in
    ERR:on-trunk)    die "you're on trunk ('$(stack_trunk)'); checkout a stack branch first." ;;
    ERR:no-parent:*) die "branch '${1#ERR:no-parent:}' has no parent. Record one with: git stack parent <parent>" ;;
    ERR:cycle)       die "parent pointers form a cycle." ;;
    ERR:*)           die "not part of a tracked stack." ;;
  esac
}

# ---- misc ----------------------------------------------------------------

sha() { git rev-parse --verify --quiet "$1^{commit}"; }

# True if $1 is an ancestor of (or equal to) $2.
is_ancestor() { git merge-base --is-ancestor "$1" "$2" 2>/dev/null; }

# Count of commits in <upstream>..<branch>.
ahead_count() { git rev-list --count "$1..$2" 2>/dev/null || echo 0; }

rebase_in_progress() {
  local d
  d=$(git rev-parse --git-path rebase-merge); [[ -d "$d" ]] && return 0
  d=$(git rev-parse --git-path rebase-apply); [[ -d "$d" ]] && return 0
  return 1
}

die() { echo "git-stack: $*" >&2; exit 1; }
info() { echo "• $*" >&2; }

cmd_parent() {
  local cur; cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD."
  if [[ $# -eq 0 ]]; then
    local p; p=$(stack_parent "$cur")
    [[ -n "$p" ]] && echo "$p" || echo "(no parent recorded for '$cur')"
    return 0
  fi
  if [[ "$1" == "--unset" ]]; then
    local p; p=$(stack_parent "$cur")
    if [[ -n "$p" ]]; then
      local child
      while read -r child; do
        [[ -n "$child" ]] || continue
        stack_set_parent "$child" "$p"
        info "reparented '$child' onto '$p'."
      done < <(stack_children "$cur")
    fi
    stack_unset_parent "$cur"; info "'$cur' is no longer tracked."; return 0
  fi
  local parent="$1"
  branch_exists "$parent" || die "no such branch: '$parent'."
  [[ "$parent" == "$cur" ]] && die "a branch can't be its own parent."
  stack_set_parent "$cur" "$parent"
  info "'$cur' now stacks on '$parent'."
}

cmd_new() {
  [[ $# -ge 1 ]] || die "usage: git stack new <name> [<parent>]"
  local name="$1" parent="${2:-$(current_branch)}"
  [[ -n "$parent" ]] || die "no parent given and HEAD is detached."
  branch_exists "$parent" || die "parent branch '$parent' does not exist."
  git checkout -b "$name"
  stack_set_parent "$name" "$parent"
  info "created '$name' stacked on '$parent'."
}

cmd_remove() {
  [[ $# -ge 1 ]] || die "usage: git stack remove <branch>"
  local branch="$1"
  local cur; cur=$(current_branch)
  branch_exists "$branch" || die "no such branch: '$branch'."
  local parent; parent=$(stack_parent "$branch")
  [[ -n "$parent" ]] || die "'$branch' has no stack parent recorded (not a tracked stack branch)."
  [[ "$branch" == "$cur" ]] && die "cannot remove the currently checked-out branch; switch away first."
  local child
  while read -r child; do
    [[ -n "$child" ]] || continue
    stack_set_parent "$child" "$parent"
    info "reparented '$child' onto '$parent'."
  done < <(stack_children "$branch")
  stack_unset_parent "$branch"
  git branch -D "$branch"
  info "deleted '$branch' (was stacked on '$parent')."
}

# Flatten an entire linear stack into its root branch (the one on trunk).
#
#   trunk <- a <- b <- c    becomes    trunk <- a   (a holds all the work)
#
# Working from the top down: check out the second-furthest branch, fast-forward
# merge the furthest into it, push, then `git stack remove` the furthest. Repeat
# until only the root branch (parent == trunk) remains.
cmd_collapse() {
  local push=1 dry=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-push) push=0 ;;
      --dry-run) dry=1 ;;
      -h|--help) echo "usage: git stack collapse [--no-push] [--dry-run]"; return 0 ;;
      *) die "usage: git stack collapse [--no-push] [--dry-run]" ;;
    esac
    shift
  done

  local cur trunk
  cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a stack branch first."
  trunk=$(stack_trunk)
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch."

  # Collect the whole stack, root -> leaf (parents before children).
  local -a chain=()
  local b
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    stack_check_err "$b"
    chain+=("$b")
  done < <(stack_collect "$cur" || true)
  [[ ${#chain[@]} -gt 0 ]] || die "'$cur' is not part of a tracked stack."

  # Collapse only makes sense on a linear stack: every non-leaf has one child.
  local i n=${#chain[@]} kids
  for ((i = 0; i < n - 1; i++)); do
    kids=$(stack_children "${chain[$i]}" | grep -c . || true)
    [[ "$kids" -le 1 ]] || die "stack is not linear: '${chain[$i]}' has multiple children; collapse only works on a linear stack."
  done

  if [[ $n -eq 1 ]]; then
    info "stack has a single branch ('${chain[0]}'); nothing to collapse."
    return 0
  fi
  [[ -z "$(git status --porcelain)" ]] || die "working tree is dirty; commit or stash first."

  if [[ $dry -eq 1 ]]; then
    echo "would collapse (top -> bottom):"
    for ((i = n - 1; i > 0; i--)); do
      printf '  ff-merge %-24s into %-24s, push, then remove %s\n' "${chain[$i]}" "${chain[$((i - 1))]}" "${chain[$i]}"
    done
    printf "  result: single branch '%s' on '%s'\n" "${chain[0]}" "$trunk"
    return 0
  fi

  # Top -> bottom: ff the branch below up to the leaf, push it, remove the leaf.
  for ((i = n - 1; i > 0; i--)); do
    local leaf="${chain[$i]}" below="${chain[$((i - 1))]}"
    info "[$((n - i))/$((n - 1))] collapsing '$leaf' into '$below'"
    git checkout --quiet "$below"
    if ! git merge --ff-only "$leaf"; then
      die "cannot fast-forward '$below' to '$leaf' (branches have diverged).
   Run 'git stack restack' first to linearise the stack, then retry."
    fi
    if [[ $push -eq 1 ]]; then
      info "pushing '$below'"; git push -u origin "$below"
    fi
    cmd_remove "$leaf"
  done

  info "collapse complete; stack flattened into '${chain[0]}' on '$trunk'."
}

# Interactive arrow-key menu. First argument is the initial 0-based selection;
# the rest are the menu items. Renders them to /dev/tty and returns the chosen
# 0-based index on stdout. Navigate with the arrow keys (or j/k), choose with
# Enter, cancel with q/Esc (returns non-zero).
_select_menu() {
  local sel="$1"; shift
  local -a items=("$@")
  local n=${#items[@]}
  [[ $n -gt 0 ]] || return 1
  [[ "$sel" -ge 0 && "$sel" -lt "$n" ]] || sel=0
  [[ -t 0 || -e /dev/tty ]] || die "git stack checkout needs an interactive terminal."

  exec 3</dev/tty
  local i key seq oldstty
  oldstty=$(stty -g <&3)
  stty -echo -icanon <&3
  # Restore the terminal no matter how we leave.
  trap 'stty "$oldstty" <&3 2>/dev/null; exec 3<&- 2>/dev/null; printf "\033[?25h" >/dev/tty' RETURN
  printf '\033[?25l' >/dev/tty  # hide cursor

  _render_menu() {
    for ((i = 0; i < n; i++)); do
      if [[ $i -eq $sel ]]; then
        printf '\033[7m> %s\033[0m\033[K\n' "${items[$i]}" >/dev/tty
      else
        printf '  %s\033[K\n' "${items[$i]}" >/dev/tty
      fi
    done
  }
  _render_menu
  while :; do
    IFS= read -rsn1 key <&3 || { echo -1; return 1; }
    case "$key" in
      $'\033')
        seq=""; read -rsn2 -t 1 seq <&3 || true
        case "$seq" in
          '[A') (( sel > 0 ))     && sel=$((sel - 1)) ;;
          '[B') (( sel < n - 1 )) && sel=$((sel + 1)) ;;
          '')   echo -1; return 1 ;;   # bare Esc
        esac ;;
      k) (( sel > 0 ))     && sel=$((sel - 1)) ;;
      j) (( sel < n - 1 )) && sel=$((sel + 1)) ;;
      q) echo -1; return 1 ;;
      '') break ;;                     # Enter
    esac
    printf '\033[%dA' "$n" >/dev/tty   # back to top of the list
    _render_menu
  done
  echo "$sel"
}

# Show a selector of every branch in the current stack (bottom -> top, parents
# first) plus a final entry for creating a new branch on the end of the stack.
# Selecting a branch checks it out; selecting the new-branch entry prompts for a
# name and creates it stacked on the stack's leaf.
cmd_checkout() {
  local cur trunk
  cur=$(current_branch)
  trunk=$(stack_trunk)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a stack branch first."
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch first."

  local -a branches=() labels=()
  local b parent marker start=0
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    stack_check_err "$b"
    parent=$(stack_parent "$b")
    [[ "$b" == "$cur" ]] && { marker=" *"; start=${#branches[@]}; } || marker=""
    branches+=("$b")
    labels+=("$b$marker  (on $parent)")
  done < <(stack_collect "$cur" || true)
  [[ ${#branches[@]} -gt 0 ]] || die "'$cur' is not part of a tracked stack."

  local leaf="${branches[$((${#branches[@]} - 1))]}"
  labels+=("＋ new branch on '$leaf'…")

  local idx
  idx=$(_select_menu "$start" "${labels[@]}") || { info "cancelled."; return 1; }

  if [[ "$idx" -lt ${#branches[@]} ]]; then
    local target="${branches[$idx]}"
    [[ "$target" == "$cur" ]] && { info "already on '$cur'."; return 0; }
    git checkout "$target"
    return 0
  fi

  # New-branch entry: prompt for a name and stack it on the leaf.
  local name=""
  printf 'new branch name (on %s): ' "$leaf" >/dev/tty
  IFS= read -r name </dev/tty || true
  name="${name#"${name%%[![:space:]]*}"}"; name="${name%"${name##*[![:space:]]}"}"
  [[ -n "$name" ]] || die "no branch name given."
  branch_exists "$name" && die "branch '$name' already exists."
  cmd_new "$name" "$leaf"
}

# Reconstruct the current branch's stack from its GitHub PRs and record the
# parent pointers locally. Each PR's base branch is treated as that branch's
# stack parent (the same invariant `git stack` enforces and create-pr-stack
# relies on), so a stack of PRs trunk <- a <- b <- c is recoverable from the
# PR base graph alone:
#
#   PR(a).base == trunk,  PR(b).base == a,  PR(c).base == b
#
# Starting from any branch in the stack we trace DOWN by following each branch's
# PR base until we reach trunk, and UP by finding every PR whose base is a branch
# already in the stack. Every branch found is fetched locally (created from
# origin/<branch> if missing) and linked with `branch.<name>.stackParent`.
cmd_infer() {
  local dry=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry=1 ;;
      -h|--help) echo "usage: git stack infer [--dry-run]"; return 0 ;;
      *) die "usage: git stack infer [--dry-run]" ;;
    esac
    shift
  done

  command -v gh >/dev/null 2>&1 || die "gh CLI not found (needed to read PRs)."
  command -v jq >/dev/null 2>&1 || die "jq not found (needed to parse PR data)."

  local cur trunk
  cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a branch in the stack first."
  trunk=$(stack_trunk)
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch first."

  # We query PRs one branch at a time rather than listing every open PR up front:
  # `base_of` reads a single branch's PR base, and the trace-UP step asks GitHub
  # directly for the PRs targeting a given base. $links accumulates the inferred
  # branch<TAB>parent edges as plain text so the script stays bash-3.2 compatible.
  info "reading PRs from GitHub…"
  base_of() { gh pr view "$1" --json baseRefName --jq '.baseRefName' 2>/dev/null || true; }

  [[ -n "$(base_of "$cur")" ]] \
    || die "no open PR found for '$cur'; can't infer its stack (open a PR or record parents manually with 'git stack parent')."

  # Trace DOWN: follow base pointers from $cur until we hit trunk, recording each
  # branch<TAB>parent edge. $inset is a space-delimited membership set (branch
  # names can't contain spaces, so this is unambiguous).
  local links="" inset=" " node="$cur" guard=0
  while :; do
    local par; par=$(base_of "$node")
    [[ -n "$par" ]] || die "no open PR found for '$node'; the stack trace broke below it."
    links+="$node"$'\t'"$par"$'\n'
    inset+="$node "
    [[ "$par" == "$trunk" ]] && break
    node="$par"
    guard=$((guard + 1)); [[ $guard -gt 1000 ]] && die "cycle in PR base pointers."
  done

  # Trace UP: BFS outward, asking GitHub for the open PRs whose base is each
  # branch already in the set. The process-substitution loop runs in the current
  # shell, so updates to $inset/$links/$queue persist.
  local -a queue=(); read -ra queue <<< "$inset"
  while [[ ${#queue[@]} -gt 0 ]]; do
    local x="${queue[0]}"; queue=("${queue[@]:1}")
    local h
    while IFS= read -r h; do
      [[ -n "$h" ]] || continue
      if [[ "$inset" != *" $h "* ]]; then
        inset+="$h "
        links+="$h"$'\t'"$x"$'\n'
        queue+=("$h")
      fi
    done < <(gh pr list --state open --base "$x" --json headRefName --jq '.[].headRefName' 2>/dev/null || true)
  done

  parent_of() { awk -F'\t' -v b="$1" '$1==b {print $2; exit}' <<< "$links"; }
  # children_of <branch> -> branches whose recorded parent is <branch>.
  children_of() { awk -F'\t' -v p="$1" '$2==p {print $1}' <<< "$links"; }

  # Order root -> leaf (parents before children) via BFS from the single root
  # (the branch whose parent is trunk) for stable, readable output.
  local root; root=$(awk -F'\t' -v t="$trunk" '$2==t {print $1; exit}' <<< "$links")
  local -a order=() bq=("$root") kid
  while [[ ${#bq[@]} -gt 0 ]]; do
    local cb="${bq[0]}"; bq=("${bq[@]:1}")
    order+=("$cb")
    while read -r kid; do
      [[ -n "$kid" ]] && bq+=("$kid")
    done < <(children_of "$cb")
  done

  info "inferred stack on '$trunk' (${#order[@]} branch(es)):"
  local b
  for b in "${order[@]}"; do
    local mark=""; [[ "$b" == "$cur" ]] && mark=" *"
    printf '    %s%s  (parent: %s)\n' "$b" "$mark" "$(parent_of "$b")" >&2
  done

  if [[ $dry -eq 1 ]]; then
    info "dry run; no branches fetched and no parents recorded."
    return 0
  fi

  info "fetching from origin…"
  git fetch origin >/dev/null 2>&1 || die "git fetch origin failed."

  for b in "${order[@]}"; do
    if branch_exists "$b"; then
      info "$b: already present locally"
    elif git rev-parse --verify --quiet "refs/remotes/origin/$b" >/dev/null; then
      git branch --quiet --track "$b" "origin/$b"
      info "$b: created from origin/$b"
    else
      die "branch '$b' has a PR but no 'origin/$b' ref after fetch."
    fi
    stack_set_parent "$b" "$(parent_of "$b")"
  done

  info "done; recorded ${#order[@]} parent pointer(s). View it with: git stack"
}

cmd_trunk() {
  if [[ $# -eq 0 ]]; then stack_trunk; return 0; fi
  git config stack.trunk "$1"; info "trunk set to '$1'."
}

# Pretty-print the tree rooted at trunk for the stack containing $cur.
cmd_show() {
  local cur trunk root
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  echo "$trunk"
  _show_subtree "$root" "$trunk" "$cur" ""
}

_show_subtree() { # branch parent currentBranch indent
  local b="$1" parent="$2" cur="$3" indent="$4"
  local ahead behind marker remote=""
  ahead=$(ahead_count "$parent" "$b")
  behind=$(ahead_count "$b" "$parent")
  [[ "$b" == "$cur" ]] && marker=" *" || marker=""
  if git rev-parse --verify --quiet "refs/remotes/origin/$b" >/dev/null; then
    if [[ "$(sha "$b")" == "$(sha "origin/$b")" ]]; then remote=" [synced]"
    else remote=" [unpushed]"; fi
  else remote=" [local]"; fi
  printf '%s└─ %s%s  (+%s/-%s vs %s)%s\n' "$indent" "$b" "$marker" "$ahead" "$behind" "$parent" "$remote"
  local child
  while read -r child; do
    [[ -n "$child" ]] && _show_subtree "$child" "$b" "$cur" "   $indent"
  done < <(stack_children "$b")
}

# List every tracked stack, not just the current one. A stack is a tree rooted
# at a branch whose parent is the trunk, so we print one tree per such root.
# Tracked branches whose parent chain never reaches trunk (dangling parent) are
# reported separately so they aren't silently dropped.
cmd_stacks() {
  local cur trunk
  cur=$(current_branch)
  trunk=$(stack_trunk)

  local -a roots=() orphans=()
  local b r
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    if [[ "$(stack_parent "$b")" == "$trunk" ]]; then
      roots+=("$b")
    else
      # Root of $b's chain; if it doesn't resolve to a trunk-rooted branch the
      # parent pointer dangles (e.g. parent was deleted).
      r=$(stack_root "$b" 2>/dev/null || true)
      [[ "$r" == ERR:* || -z "$r" ]] && orphans+=("$b")
    fi
  done < <(stack_tracked_branches)

  if [[ ${#roots[@]} -eq 0 && ${#orphans[@]} -eq 0 ]]; then
    info "no tracked stacks found (record one with: git stack parent <parent>)."
    return 0
  fi

  if [[ ${#roots[@]} -gt 0 ]]; then
    IFS=$'\n' roots=($(printf '%s\n' "${roots[@]}" | sort)); unset IFS
    local n=${#roots[@]}
    printf '%d stack%s on %s:\n' "$n" "$([[ $n -eq 1 ]] || echo s)" "$trunk"
    for r in "${roots[@]}"; do
      echo
      echo "$trunk"
      _show_subtree "$r" "$trunk" "$cur" ""
    done
  fi

  if [[ ${#orphans[@]} -gt 0 ]]; then
    echo
    info "untracked-parent branches (parent chain doesn't reach '$trunk'):"
    IFS=$'\n' orphans=($(printf '%s\n' "${orphans[@]}" | sort)); unset IFS
    for b in "${orphans[@]}"; do
      printf '  %s  (parent: %s)\n' "$b" "$(stack_parent "$b")"
    done
  fi
}

# Like `git stack`, but label each branch with its GitHub PR (via `gh`):
#   [PR <n>](<url>): (+<adds>/-<dels>) <title>

cmd_prs() {
  if [[ "${1:-}" == "list" ]]; then shift; cmd_prs_list "$@"; return; fi
  command -v gh >/dev/null 2>&1 || die "gh CLI not found (needed for PR info)."
  local cur trunk root
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  _show_subtree_prs "$root" "$cur" ""
}

# Like `git stack prs`, but a flat one-branch-per-line list (bottom -> top,
# parents before children) with no tree art — easy for an LLM to parse:
#   - <branch> [current] (parent: <parent>) — PR #<n> [<state>] (+<add>/-<del>) "<title>" <url>
#   - <branch> (parent: <parent>) — no PR (+<add>/-<del>)
cmd_prs_list() {
  command -v gh >/dev/null 2>&1 || die "gh CLI not found (needed for PR info)."
  local cur trunk
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  stack_root "$cur" >/dev/null || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  echo "trunk: $trunk"
  local b parent marker pr num url add del title state
  while IFS= read -r b; do
    [[ -n "$b" ]] || continue
    parent=$(stack_parent "$b")
    [[ "$b" == "$cur" ]] && marker=" [current]" || marker=""
    pr=$(gh pr view "$b" --json number,url,additions,deletions,title,state 2>/dev/null || true)
    if [[ -n "$pr" ]]; then
      num=$(jq -r '.number'    <<< "$pr")
      url=$(jq -r '.url'       <<< "$pr")
      add=$(jq -r '.additions' <<< "$pr")
      del=$(jq -r '.deletions' <<< "$pr")
      title=$(jq -r '.title'   <<< "$pr")
      state=$(jq -r '.state'   <<< "$pr")
      printf -- '- %s%s (parent: %s) — PR #%s [%s] (+%s/-%s) "%s" %s\n' \
        "$b" "$marker" "$parent" "$num" "$state" "$add" "$del" "$title" "$url"
    else
      local stat
      stat=$(git diff --shortstat "$parent".."$b" 2>/dev/null || true)
      add=$(echo "$stat" | grep -o '[0-9]* insertion' | grep -o '[0-9]*' || echo 0)
      del=$(echo "$stat" | grep -o '[0-9]* deletion' | grep -o '[0-9]*' || echo 0)
      printf -- '- %s%s (parent: %s) — no PR (+%s/-%s)\n' \
        "$b" "$marker" "$parent" "${add:-0}" "${del:-0}"
    fi
  done < <(stack_collect "$cur")
}

_show_subtree_prs() { # branch currentBranch indent
  local b="$1" cur="$2" indent="$3"
  local marker num url add del title label
  [[ "$b" == "$cur" ]] && marker="* " || marker=""
  local pr; pr=$(gh pr view "$b" --json number,url,additions,deletions,title 2>/dev/null || true)
  if [[ -n "$pr" ]]; then
    num=$(jq -r '.number' <<< "$pr")
    url=$(jq -r '.url'    <<< "$pr")
    add=$(jq -r '.additions' <<< "$pr")
    del=$(jq -r '.deletions' <<< "$pr")
    title=$(jq -r '.title' <<< "$pr")
    label="[PR $num]($url): (+$add / -$del) $title"
  else
    local stat
    stat=$(git diff --shortstat "$(stack_parent "$b")".."$b" 2>/dev/null || true)
    add=$(echo "$stat" | grep -o '[0-9]* insertion' | grep -o '[0-9]*' || echo 0)
    del=$(echo "$stat" | grep -o '[0-9]* deletion' | grep -o '[0-9]*' || echo 0)
    label="$b (no PR): (+${add:-0} / -${del:-0})"
  fi
  if [[ -z "$indent" ]]; then
    printf '%s%s\n' "$marker" "$label"
  else
    printf '%s└─ %s%s\n' "$indent" "$marker" "$label"
  fi
  local child
  while read -r child; do
    [[ -n "$child" ]] && _show_subtree_prs "$child" "$cur" "   $indent"
  done < <(stack_children "$b")
}

# Machine-readable: print "<branch>\t<parent>" for every branch in the current
# stack, bottom -> top (parents before children). No network. For scripts/skills.
cmd_list() {
  local cur root b
  cur=$(current_branch)
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."
  while IFS= read -r b; do
    [[ -n "$b" ]] && printf '%s\t%s\n' "$b" "$(stack_parent "$b")"
  done < <(stack_collect "$cur")
}

# ---- restack -------------------------------------------------------------
# Rebase an entire branch stack into one clean linear history.
#
#   trunk <- a <- b <- c   (each branch recorded via `git stack parent`)
#
# Run from ANY branch in the stack. restack will:
#   1. fetch, and fast-forward each branch (and trunk) to its remote when the
#      remote is strictly ahead (adopts review fixups pushed elsewhere);
#   2. rebase every branch onto its parent's new tip, bottom -> top, so each
#      branch contributes only its own commits (no duplication even when a
#      parent diverged, e.g. a review fixup a' landed on `a`);
#   3. force-push (--force-with-lease) every branch in the stack;
#   4. return you to the branch you started on.
#
# Trunk's history is never rewritten or force-pushed.
#
# State file ($GIT_DIR/stack-restack-state) format:
#   ORIG_REF=<branch>
#   PUSH=0|1
#   OFFLINE=0|1
#   IDX=<next plan index to process>
#   --PLAN--
#   <branch>\t<parent>\t<parentBaseSha>\t<branchOrigSha>
#   ...
# STATE and TAB are set as locals in cmd_restack; bash's dynamic scoping makes
# them visible to the restack_* helpers it calls.

restack_usage() {
  cat >&2 <<'EOF'
usage: git stack restack [--no-push] [--offline] [--dry-run]
       git stack restack --continue   # resume after resolving a rebase conflict
       git stack restack --abort      # undo: restore every branch to its pre-restack tip
EOF
  exit "${1:-0}"
}

restack_save_idx() {
  local tmp="$STATE.tmp"
  awk -v idx="$1" 'BEGIN{done=0} /^IDX=/{print "IDX=" idx; done=1; next} {print}' "$STATE" > "$tmp"
  mv "$tmp" "$STATE"
}

restack_load_header() { # key
  grep -m1 "^$1=" "$STATE" | cut -d= -f2-
}

restack_load_plan() { # prints plan lines (after --PLAN--)
  sed -n '/^--PLAN--$/,$p' "$STATE" | tail -n +2
}

restack_clear_state() { rm -f "$STATE"; }

# Fast-forward a local branch to its remote when the remote is strictly ahead;
# stop hard on genuine divergence. Returns 0 if safe to proceed.
restack_sync_one() { # branch
  local b="$1" r local_sha remote_sha
  r="origin/$b"
  git rev-parse --verify --quiet "refs/remotes/$r" >/dev/null || return 0  # not on remote yet
  local_sha=$(sha "$b"); remote_sha=$(sha "$r")
  [[ "$local_sha" == "$remote_sha" ]] && return 0
  if is_ancestor "$b" "$r"; then
    git update-ref "refs/heads/$b" "$remote_sha"
    info "fast-forwarded $b to origin/$b"
  elif is_ancestor "$r" "$b"; then
    return 0  # local ahead; will be pushed at the end
  else
    die "branch '$b' has diverged from origin/$b (both have unique commits).
   Resolve it manually, or rerun with --offline to skip syncing."
  fi
}

restack_build_plan() { # writes STATE; echoes nothing
  local start trunk orig _ln branches=()
  start=$(current_branch)
  [[ -n "$start" ]] || die "detached HEAD; checkout a stack branch first."
  trunk=$(stack_trunk)

  while IFS= read -r _ln; do branches+=("$_ln"); done < <(stack_collect "$start" || true)
  [[ ${#branches[@]} -gt 0 ]] \
    || die "'$start' is not part of a tracked stack. Set its parent:  git stack parent $trunk"
  stack_check_err "${branches[0]}"

  [[ -z "$(git status --porcelain)" ]] || die "working tree is dirty; commit or stash first."

  orig="$start"

  if [[ "$OFFLINE" == 0 ]]; then
    info "fetching origin..."
    git fetch --quiet origin "$trunk" "${branches[@]}" 2>/dev/null || git fetch --quiet origin || true
    restack_sync_one "$trunk"
    local b; for b in "${branches[@]}"; do restack_sync_one "$b"; done
  fi

  # Snapshot parent bases + each branch's original tip (post-sync, pre-rebase).
  {
    echo "ORIG_REF=$orig"
    echo "PUSH=$PUSH"
    echo "OFFLINE=$OFFLINE"
    echo "IDX=0"
    echo "--PLAN--"
    local b parent base orig_sha
    for b in "${branches[@]}"; do
      parent=$(stack_parent "$b")
      base=$(sha "$parent") || die "parent '$parent' of '$b' has no commit."
      orig_sha=$(sha "$b")
      printf '%s\t%s\t%s\t%s\n' "$b" "$parent" "$base" "$orig_sha"
    done
  } > "$STATE"
}

restack_run_loop() {
  local idx n line b parent base _orig _ln
  local -a PLAN
  idx=$(restack_load_header IDX)
  PLAN=()
  while IFS= read -r _ln; do PLAN+=("$_ln"); done < <(restack_load_plan)
  n=${#PLAN[@]}

  while [[ $idx -lt $n ]]; do
    line="${PLAN[$idx]}"
    IFS="$TAB" read -r b parent base _orig <<<"$line"
    # Already rebased onto its parent? Skip it. This is only ever true after the
    # branch has landed on its (possibly rewritten) parent, so a not-yet-done
    # branch — still on its old base — is never wrongly skipped. It keeps the
    # loop idempotent, so --continue works whether or not the user finished the
    # conflicted rebase by hand; re-running from the stale snapshot base would
    # otherwise replay the parent's commits and duplicate them.
    if is_ancestor "$parent" "$b"; then
      info "[$((idx + 1))/$n] $b already on $parent; skipping"
      idx=$((idx + 1)); restack_save_idx "$idx"
      continue
    fi
    info "[$((idx + 1))/$n] rebasing $b onto $parent"
    if ! git rebase --no-update-refs --onto "$parent" "$base" "$b"; then
      cat >&2 <<EOF

git stack restack: conflict while rebasing '$b'.
   1. resolve the conflicts and stage them (git add …)
   2. continue:                 git stack restack --continue
      (finishing the rebase yourself with 'git rebase --continue' first is fine too)
   (or abandon everything with: git stack restack --abort)
EOF
      exit 1
    fi
    idx=$((idx + 1)); restack_save_idx "$idx"
  done

  restack_finish
}

restack_finish() {
  local push offline orig
  push=$(restack_load_header PUSH); offline=$(restack_load_header OFFLINE); orig=$(restack_load_header ORIG_REF)

  if [[ "$push" == 1 && "$offline" == 0 ]]; then
    local line b _p _b _o
    while IFS= read -r line; do
      IFS="$TAB" read -r b _p _b _o <<<"$line"
      info "pushing $b (--force-with-lease)"
      git push -u --force-with-lease origin "$b"
    done < <(restack_load_plan)
  fi

  git checkout --quiet "$orig"
  restack_clear_state
  info "restack complete; back on '$orig'."
}

restack_do_continue() {
  [[ -f "$STATE" ]] || die "no restack in progress."
  if rebase_in_progress; then
    if ! git rebase --continue; then
      echo "git stack restack: rebase still has conflicts; resolve them and rerun 'git stack restack --continue'." >&2
      exit 1
    fi
  fi
  # The loop's idempotency guard advances past any branch already rebased —
  # whether we just finished it above or the user finished it by hand.
  restack_run_loop
}

restack_do_abort() {
  [[ -f "$STATE" ]] || die "no restack in progress."
  rebase_in_progress && git rebase --abort || true
  local line b _p _base orig
  while IFS= read -r line; do
    IFS="$TAB" read -r b _p _base orig <<<"$line"
    git update-ref "refs/heads/$b" "$orig"
  done < <(restack_load_plan)
  git checkout --quiet "$(restack_load_header ORIG_REF)"
  restack_clear_state
  info "restack aborted; all stack branches restored to their pre-restack tips."
}

restack_dry_run() {
  local line b parent base orig
  echo "would restack (bottom -> top):"
  while IFS= read -r line; do
    IFS="$TAB" read -r b parent base orig <<<"$line"
    printf '  %-24s onto %-20s (base %.10s, tip %.10s)\n' "$b" "$parent" "$base" "$orig"
  done < <(restack_load_plan)
}

cmd_restack() {
  local STATE TAB
  STATE="$(git rev-parse --git-dir)/stack-restack-state"
  TAB=$'\t'

  local PUSH=1 OFFLINE=0 ACTION="run" DRY=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-push)   PUSH=0 ;;
      --offline)   OFFLINE=1; PUSH=0 ;;
      --dry-run)   DRY=1 ;;
      --continue)  ACTION="continue" ;;
      --abort)     ACTION="abort" ;;
      -h|--help)   restack_usage 0 ;;
      *) die "unknown option: $1 (try: git stack restack --help)" ;;
    esac
    shift
  done

  case "$ACTION" in
    continue) restack_do_continue ;;
    abort)    restack_do_abort ;;
    run)
      [[ -f "$STATE" ]] && die "a restack is already in progress; use --continue or --abort."
      restack_build_plan
      if [[ "$DRY" == 1 ]]; then restack_dry_run; restack_clear_state; exit 0; fi
      restack_run_loop
      ;;
  esac
}

# ---- sync ----------------------------------------------------------------
# Drop merged branches from the stack, then restack what remains.
#
#   trunk <- a <- b <- c   and `a` is merged   =>   trunk <- b <- c
#   trunk <- a <- b <- c   and `b` is merged   =>   trunk <- a <- c
#
# A branch counts as merged if its GitHub PR is in the MERGED state, or its tip
# is already an ancestor of origin/<trunk> (a non-squash or local merge). Each
# merged branch is removed like `git stack remove` (its children reparent onto
# its parent and the local branch is deleted); reading the parent fresh each
# time means consecutive merged branches collapse correctly. Whatever remains is
# handed to `git stack restack` to rebase + push into one clean linear history.
cmd_sync() {
  local push=1 offline=0 dry=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-push) push=0 ;;
      --offline) offline=1; push=0 ;;
      --dry-run) dry=1 ;;
      -h|--help) echo "usage: git stack sync [--no-push] [--offline] [--dry-run]"; return 0 ;;
      *) die "usage: git stack sync [--no-push] [--offline] [--dry-run]" ;;
    esac
    shift
  done

  local cur trunk
  cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a stack branch first."
  trunk=$(stack_trunk)
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch first."

  # Collect the whole stack, root -> leaf (parents before children).
  local -a chain=()
  local b
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    stack_check_err "$b"
    chain+=("$b")
  done < <(stack_collect "$cur" || true)
  [[ ${#chain[@]} -gt 0 ]] || die "'$cur' is not part of a tracked stack."

  # Fetch so both merge detection and the later restack see the latest remote.
  if [[ $offline -eq 0 ]]; then
    info "fetching origin…"
    git fetch --quiet origin 2>/dev/null || info "git fetch origin failed; continuing with local state."
  fi

  # Which branches are merged? Prefer each branch's GitHub PR state (catches
  # squash merges and merges into a non-trunk parent); fall back to git ancestry
  # when gh is absent or the branch has no PR.
  local have_gh=0
  if command -v gh >/dev/null 2>&1; then
    have_gh=1
  else
    info "gh CLI not found; detecting merges by git ancestry only."
  fi

  # Compare ancestry against origin/<trunk> when present (most up-to-date),
  # otherwise the local trunk ref.
  local trunk_ref="$trunk"
  git rev-parse --verify --quiet "refs/remotes/origin/$trunk" >/dev/null \
    && trunk_ref="origin/$trunk"

  is_merged() { # branch ; uses $have_gh and $trunk_ref
    local x="$1"
    if [[ $have_gh -eq 1 ]]; then
      [[ "$(gh pr view "$x" --json state --jq '.state' 2>/dev/null || true)" == "MERGED" ]] \
        && return 0
    fi
    is_ancestor "$x" "$trunk_ref" && return 0
    return 1
  }

  local -a merged=() survivors=()
  for b in "${chain[@]}"; do
    if is_merged "$b"; then merged+=("$b"); else survivors+=("$b"); fi
  done

  if [[ $dry -eq 1 ]]; then
    if [[ ${#merged[@]} -eq 0 ]]; then
      echo "no merged branches; would restack the stack as-is."
    else
      echo "would drop merged branch(es):"
      for b in "${merged[@]}"; do
        printf '  %-24s (was on %s)\n' "$b" "$(stack_parent "$b")"
      done
      echo "remaining stack would be (then restacked):"
      if [[ ${#survivors[@]} -eq 0 ]]; then
        printf '  (empty — the whole stack is merged)\n'
      else
        for b in "${survivors[@]}"; do printf '  %s\n' "$b"; done
      fi
    fi
    return 0
  fi

  [[ -z "$(git status --porcelain)" ]] || die "working tree is dirty; commit or stash first."

  if [[ ${#merged[@]} -eq 0 ]]; then
    info "no merged branches to drop; restacking."
  else
    # If we're sitting on a branch about to be deleted, move to a survivor first:
    # the nearest surviving ancestor, else the root-most survivor, else trunk.
    local in_merged=" ${merged[*]} "
    if [[ "$in_merged" == *" $cur "* ]]; then
      local target="" node="$cur" p
      while :; do
        p=$(stack_parent "$node")
        [[ -z "$p" || "$p" == "$trunk" ]] && break
        if [[ "$in_merged" != *" $p "* ]]; then target="$p"; break; fi
        node="$p"
      done
      if [[ -z "$target" && ${#survivors[@]} -gt 0 ]]; then target="${survivors[0]}"; fi
      [[ -z "$target" ]] && target="$trunk"
      info "leaving merged branch '$cur'; checking out '$target'."
      git checkout --quiet "$target"
    fi

    for b in "${merged[@]}"; do
      info "dropping merged branch '$b'."
      cmd_remove "$b"
    done
  fi

  if [[ ${#survivors[@]} -eq 0 ]]; then
    info "the whole stack was merged; nothing left to restack."
    return 0
  fi

  # Restack the remainder into a clean linear history (fetches + pushes too).
  local -a rargs=()
  [[ $push -eq 0 ]] && rargs+=(--no-push)
  [[ $offline -eq 1 ]] && rargs+=(--offline)
  cmd_restack ${rargs[@]+"${rargs[@]}"}
}

sub="${1:-show}"; [[ $# -gt 0 ]] && shift || true
case "$sub" in
  show|"")        cmd_show "$@" ;;
  list-stacks|all) cmd_stacks "$@" ;;
  prs)            cmd_prs "$@" ;;
  list)           cmd_list "$@" ;;
  checkout|co)    cmd_checkout "$@" ;;
  infer)          cmd_infer "$@" ;;
  parent)         cmd_parent "$@" ;;
  new)            cmd_new "$@" ;;
  remove)         cmd_remove "$@" ;;
  collapse)       cmd_collapse "$@" ;;
  restack)        cmd_restack "$@" ;;
  sync)           cmd_sync "$@" ;;
  trunk)          cmd_trunk "$@" ;;
  -h|--help|help) sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//; $d' ;;
  *) die "unknown subcommand: '$sub' (try: git stack --help)" ;;
esac
