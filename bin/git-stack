#!/usr/bin/env bash
# git-stack — manage PR-stack metadata (parent pointers) and view the stack.
#
# Subcommands:
#   git stack                       show the stack you're currently on (a tree)
#   git stack prs                   show the stack, each branch labelled with its GitHub PR
#   git stack prs list              flat one-branch-per-line PR list (LLM-friendly)
#   git stack list                  print "<branch>\t<parent>" bottom->top (for scripts)
#   git stack checkout              pick a branch in the current stack (or create a
#                                   new one on the end) from an interactive selector
#   git stack parent [<parent>]     show, or set, the current branch's parent
#   git stack parent --unset        stop tracking the current branch, moving its
#                                   children onto the current branch's parent
#   git stack new <name> [<parent>] create a branch and record its parent
#                                   (parent defaults to the current branch)
#   git stack remove <name>         delete a branch and re-parent its children onto its parent
#   git stack collapse              flatten a linear stack into its root branch
#                                   (ff-merge each branch down, push, remove the leaf)
#   git stack trunk [<branch>]      show, or set, the trunk (default: origin HEAD)
#
# The restack operation lives in its own command: `git restack`.

set -euo pipefail
# shellcheck source=git-stack-lib.sh
source "${GIT_STACK_LIB:-$HOME/.bin/git-stack-lib.sh}"

cmd_parent() {
  local cur; cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD."
  if [[ $# -eq 0 ]]; then
    local p; p=$(stack_parent "$cur")
    [[ -n "$p" ]] && echo "$p" || echo "(no parent recorded for '$cur')"
    return 0
  fi
  if [[ "$1" == "--unset" ]]; then
    local p; p=$(stack_parent "$cur")
    if [[ -n "$p" ]]; then
      local child
      while read -r child; do
        [[ -n "$child" ]] || continue
        stack_set_parent "$child" "$p"
        info "reparented '$child' onto '$p'."
      done < <(stack_children "$cur")
    fi
    stack_unset_parent "$cur"; info "'$cur' is no longer tracked."; return 0
  fi
  local parent="$1"
  branch_exists "$parent" || die "no such branch: '$parent'."
  [[ "$parent" == "$cur" ]] && die "a branch can't be its own parent."
  stack_set_parent "$cur" "$parent"
  info "'$cur' now stacks on '$parent'."
}

cmd_new() {
  [[ $# -ge 1 ]] || die "usage: git stack new <name> [<parent>]"
  local name="$1" parent="${2:-$(current_branch)}"
  [[ -n "$parent" ]] || die "no parent given and HEAD is detached."
  branch_exists "$parent" || die "parent branch '$parent' does not exist."
  git checkout -b "$name"
  stack_set_parent "$name" "$parent"
  info "created '$name' stacked on '$parent'."
}

cmd_remove() {
  [[ $# -ge 1 ]] || die "usage: git stack remove <branch>"
  local branch="$1"
  local cur; cur=$(current_branch)
  branch_exists "$branch" || die "no such branch: '$branch'."
  local parent; parent=$(stack_parent "$branch")
  [[ -n "$parent" ]] || die "'$branch' has no stack parent recorded (not a tracked stack branch)."
  [[ "$branch" == "$cur" ]] && die "cannot remove the currently checked-out branch; switch away first."
  local child
  while read -r child; do
    [[ -n "$child" ]] || continue
    stack_set_parent "$child" "$parent"
    info "reparented '$child' onto '$parent'."
  done < <(stack_children "$branch")
  stack_unset_parent "$branch"
  git branch -D "$branch"
  info "deleted '$branch' (was stacked on '$parent')."
}

# Flatten an entire linear stack into its root branch (the one on trunk).
#
#   trunk <- a <- b <- c    becomes    trunk <- a   (a holds all the work)
#
# Working from the top down: check out the second-furthest branch, fast-forward
# merge the furthest into it, push, then `git stack remove` the furthest. Repeat
# until only the root branch (parent == trunk) remains.
cmd_collapse() {
  local push=1 dry=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-push) push=0 ;;
      --dry-run) dry=1 ;;
      -h|--help) echo "usage: git stack collapse [--no-push] [--dry-run]"; return 0 ;;
      *) die "usage: git stack collapse [--no-push] [--dry-run]" ;;
    esac
    shift
  done

  local cur trunk
  cur=$(current_branch)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a stack branch first."
  trunk=$(stack_trunk)
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch."

  # Collect the whole stack, root -> leaf (parents before children).
  local -a chain=()
  local b
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    case "$b" in
      ERR:on-trunk)    die "you're on trunk ('$trunk'); checkout a stack branch." ;;
      ERR:no-parent:*) die "branch '${b#ERR:no-parent:}' has no parent. Record one with: git stack parent <parent>" ;;
      ERR:cycle)       die "parent pointers form a cycle." ;;
      ERR:*)           die "'$cur' is not part of a tracked stack." ;;
    esac
    chain+=("$b")
  done < <(stack_collect "$cur" || true)
  [[ ${#chain[@]} -gt 0 ]] || die "'$cur' is not part of a tracked stack."

  # Collapse only makes sense on a linear stack: every non-leaf has one child.
  local i n=${#chain[@]} kids
  for ((i = 0; i < n - 1; i++)); do
    kids=$(stack_children "${chain[$i]}" | grep -c . || true)
    [[ "$kids" -le 1 ]] || die "stack is not linear: '${chain[$i]}' has multiple children; collapse only works on a linear stack."
  done

  if [[ $n -eq 1 ]]; then
    info "stack has a single branch ('${chain[0]}'); nothing to collapse."
    return 0
  fi
  [[ -z "$(git status --porcelain)" ]] || die "working tree is dirty; commit or stash first."

  if [[ $dry -eq 1 ]]; then
    echo "would collapse (top -> bottom):"
    for ((i = n - 1; i > 0; i--)); do
      printf '  ff-merge %-24s into %-24s, push, then remove %s\n' "${chain[$i]}" "${chain[$((i - 1))]}" "${chain[$i]}"
    done
    printf "  result: single branch '%s' on '%s'\n" "${chain[0]}" "$trunk"
    return 0
  fi

  # Top -> bottom: ff the branch below up to the leaf, push it, remove the leaf.
  for ((i = n - 1; i > 0; i--)); do
    local leaf="${chain[$i]}" below="${chain[$((i - 1))]}"
    info "[$((n - i))/$((n - 1))] collapsing '$leaf' into '$below'"
    git checkout --quiet "$below"
    if ! git merge --ff-only "$leaf"; then
      die "cannot fast-forward '$below' to '$leaf' (branches have diverged).
   Run 'git restack' first to linearise the stack, then retry."
    fi
    if [[ $push -eq 1 ]]; then
      if git rev-parse --verify --quiet "refs/remotes/origin/$below" >/dev/null; then
        info "pushing '$below'"; git push origin "$below"
      else
        info "pushing '$below' (new, -u)"; git push -u origin "$below"
      fi
    fi
    cmd_remove "$leaf"
  done

  info "collapse complete; stack flattened into '${chain[0]}' on '$trunk'."
}

# Interactive arrow-key menu. First argument is the initial 0-based selection;
# the rest are the menu items. Renders them to /dev/tty and returns the chosen
# 0-based index on stdout. Navigate with the arrow keys (or j/k), choose with
# Enter, cancel with q/Esc (returns non-zero).
_select_menu() {
  local sel="$1"; shift
  local -a items=("$@")
  local n=${#items[@]}
  [[ $n -gt 0 ]] || return 1
  [[ "$sel" -ge 0 && "$sel" -lt "$n" ]] || sel=0
  [[ -t 0 || -e /dev/tty ]] || die "git stack checkout needs an interactive terminal."

  exec 3</dev/tty
  local i key seq oldstty
  oldstty=$(stty -g <&3)
  stty -echo -icanon <&3
  # Restore the terminal no matter how we leave.
  trap 'stty "$oldstty" <&3 2>/dev/null; exec 3<&- 2>/dev/null; printf "\033[?25h" >/dev/tty' RETURN
  printf '\033[?25l' >/dev/tty  # hide cursor

  _render_menu() {
    for ((i = 0; i < n; i++)); do
      if [[ $i -eq $sel ]]; then
        printf '\033[7m> %s\033[0m\033[K\n' "${items[$i]}" >/dev/tty
      else
        printf '  %s\033[K\n' "${items[$i]}" >/dev/tty
      fi
    done
  }
  _render_menu
  while :; do
    IFS= read -rsn1 key <&3 || { echo -1; return 1; }
    case "$key" in
      $'\033')
        seq=""; read -rsn2 -t 1 seq <&3 || true
        case "$seq" in
          '[A') (( sel > 0 ))     && sel=$((sel - 1)) ;;
          '[B') (( sel < n - 1 )) && sel=$((sel + 1)) ;;
          '')   echo -1; return 1 ;;   # bare Esc
        esac ;;
      k) (( sel > 0 ))     && sel=$((sel - 1)) ;;
      j) (( sel < n - 1 )) && sel=$((sel + 1)) ;;
      q) echo -1; return 1 ;;
      '') break ;;                     # Enter
    esac
    printf '\033[%dA' "$n" >/dev/tty   # back to top of the list
    _render_menu
  done
  echo "$sel"
}

# Show a selector of every branch in the current stack (bottom -> top, parents
# first) plus a final entry for creating a new branch on the end of the stack.
# Selecting a branch checks it out; selecting the new-branch entry prompts for a
# name and creates it stacked on the stack's leaf.
cmd_checkout() {
  local cur trunk
  cur=$(current_branch)
  trunk=$(stack_trunk)
  [[ -n "$cur" ]] || die "detached HEAD; checkout a stack branch first."
  [[ "$cur" != "$trunk" ]] || die "you're on trunk ('$trunk'); checkout a stack branch first."

  local -a branches=() labels=()
  local b parent marker start=0
  while IFS= read -r b; do
    [[ -z "$b" ]] && continue
    case "$b" in
      ERR:on-trunk)    die "you're on trunk ('$trunk'); checkout a stack branch first." ;;
      ERR:no-parent:*) die "branch '${b#ERR:no-parent:}' has no parent. Record one with: git stack parent <parent>" ;;
      ERR:cycle)       die "parent pointers form a cycle." ;;
      ERR:*)           die "'$cur' is not part of a tracked stack." ;;
    esac
    parent=$(stack_parent "$b")
    [[ "$b" == "$cur" ]] && { marker=" *"; start=${#branches[@]}; } || marker=""
    branches+=("$b")
    labels+=("$b$marker  (on $parent)")
  done < <(stack_collect "$cur" || true)
  [[ ${#branches[@]} -gt 0 ]] || die "'$cur' is not part of a tracked stack."

  local leaf="${branches[$((${#branches[@]} - 1))]}"
  labels+=("＋ new branch on '$leaf'…")

  local idx
  idx=$(_select_menu "$start" "${labels[@]}") || { info "cancelled."; return 1; }

  if [[ "$idx" -lt ${#branches[@]} ]]; then
    local target="${branches[$idx]}"
    [[ "$target" == "$cur" ]] && { info "already on '$cur'."; return 0; }
    git checkout "$target"
    return 0
  fi

  # New-branch entry: prompt for a name and stack it on the leaf.
  local name=""
  printf 'new branch name (on %s): ' "$leaf" >/dev/tty
  IFS= read -r name </dev/tty || true
  name="${name#"${name%%[![:space:]]*}"}"; name="${name%"${name##*[![:space:]]}"}"
  [[ -n "$name" ]] || die "no branch name given."
  branch_exists "$name" && die "branch '$name' already exists."
  cmd_new "$name" "$leaf"
}

cmd_trunk() {
  if [[ $# -eq 0 ]]; then stack_trunk; return 0; fi
  git config stack.trunk "$1"; info "trunk set to '$1'."
}

# Pretty-print the tree rooted at trunk for the stack containing $cur.
cmd_show() {
  local cur trunk root
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  echo "$trunk"
  _show_subtree "$root" "$trunk" "$cur" ""
}

_show_subtree() { # branch parent currentBranch indent
  local b="$1" parent="$2" cur="$3" indent="$4"
  local ahead behind marker remote=""
  ahead=$(ahead_count "$parent" "$b")
  behind=$(ahead_count "$b" "$parent")
  [[ "$b" == "$cur" ]] && marker=" *" || marker=""
  if git rev-parse --verify --quiet "refs/remotes/origin/$b" >/dev/null; then
    if [[ "$(sha "$b")" == "$(sha "origin/$b")" ]]; then remote=" [synced]"
    else remote=" [unpushed]"; fi
  else remote=" [local]"; fi
  printf '%s└─ %s%s  (+%s/-%s vs %s)%s\n' "$indent" "$b" "$marker" "$ahead" "$behind" "$parent" "$remote"
  local child
  while read -r child; do
    [[ -n "$child" ]] && _show_subtree "$child" "$b" "$cur" "   $indent"
  done < <(stack_children "$b")
}

# Like `git stack`, but label each branch with its GitHub PR (via `gh`):
#   [PR <n>](<url>): (+<adds>/-<dels>) <title>

cmd_prs() {
  if [[ "${1:-}" == "list" ]]; then shift; cmd_prs_list "$@"; return; fi
  command -v gh >/dev/null 2>&1 || die "gh CLI not found (needed for PR info)."
  local cur trunk root
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  _show_subtree_prs "$root" "$cur" ""
}

# Like `git stack prs`, but a flat one-branch-per-line list (bottom -> top,
# parents before children) with no tree art — easy for an LLM to parse:
#   - <branch> [current] (parent: <parent>) — PR #<n> [<state>] (+<add>/-<del>) "<title>" <url>
#   - <branch> (parent: <parent>) — no PR (+<add>/-<del>)
cmd_prs_list() {
  command -v gh >/dev/null 2>&1 || die "gh CLI not found (needed for PR info)."
  local cur trunk
  cur=$(current_branch)
  trunk=$(stack_trunk)
  if [[ -z "$cur" || "$cur" == "$trunk" ]]; then
    die "checkout a stack branch to view its stack (you're on '${cur:-detached HEAD}')."
  fi
  stack_root "$cur" >/dev/null || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."

  echo "trunk: $trunk"
  local b parent marker pr num url add del title state
  while IFS= read -r b; do
    [[ -n "$b" ]] || continue
    parent=$(stack_parent "$b")
    [[ "$b" == "$cur" ]] && marker=" [current]" || marker=""
    pr=$(gh pr view "$b" --json number,url,additions,deletions,title,state 2>/dev/null || true)
    if [[ -n "$pr" ]]; then
      num=$(jq -r '.number'    <<< "$pr")
      url=$(jq -r '.url'       <<< "$pr")
      add=$(jq -r '.additions' <<< "$pr")
      del=$(jq -r '.deletions' <<< "$pr")
      title=$(jq -r '.title'   <<< "$pr")
      state=$(jq -r '.state'   <<< "$pr")
      printf -- '- %s%s (parent: %s) — PR #%s [%s] (+%s/-%s) "%s" %s\n' \
        "$b" "$marker" "$parent" "$num" "$state" "$add" "$del" "$title" "$url"
    else
      local stat
      stat=$(git diff --shortstat "$parent".."$b" 2>/dev/null || true)
      add=$(echo "$stat" | grep -o '[0-9]* insertion' | grep -o '[0-9]*' || echo 0)
      del=$(echo "$stat" | grep -o '[0-9]* deletion' | grep -o '[0-9]*' || echo 0)
      printf -- '- %s%s (parent: %s) — no PR (+%s/-%s)\n' \
        "$b" "$marker" "$parent" "${add:-0}" "${del:-0}"
    fi
  done < <(stack_collect "$cur")
}

_show_subtree_prs() { # branch currentBranch indent
  local b="$1" cur="$2" indent="$3"
  local marker num url add del title label
  [[ "$b" == "$cur" ]] && marker="* " || marker=""
  local pr; pr=$(gh pr view "$b" --json number,url,additions,deletions,title 2>/dev/null || true)
  if [[ -n "$pr" ]]; then
    num=$(jq -r '.number' <<< "$pr")
    url=$(jq -r '.url'    <<< "$pr")
    add=$(jq -r '.additions' <<< "$pr")
    del=$(jq -r '.deletions' <<< "$pr")
    title=$(jq -r '.title' <<< "$pr")
    label="[PR $num]($url): (+$add / -$del) $title"
  else
    local stat
    stat=$(git diff --shortstat "$(stack_parent "$b")".."$b" 2>/dev/null || true)
    add=$(echo "$stat" | grep -o '[0-9]* insertion' | grep -o '[0-9]*' || echo 0)
    del=$(echo "$stat" | grep -o '[0-9]* deletion' | grep -o '[0-9]*' || echo 0)
    label="$b (no PR): (+${add:-0} / -${del:-0})"
  fi
  if [[ -z "$indent" ]]; then
    printf '%s%s\n' "$marker" "$label"
  else
    printf '%s└─ %s%s\n' "$indent" "$marker" "$label"
  fi
  local child
  while read -r child; do
    [[ -n "$child" ]] && _show_subtree_prs "$child" "$cur" "   $indent"
  done < <(stack_children "$b")
}

# Machine-readable: print "<branch>\t<parent>" for every branch in the current
# stack, bottom -> top (parents before children). No network. For scripts/skills.
cmd_list() {
  local cur root b
  cur=$(current_branch)
  root=$(stack_root "$cur") || die "'$cur' is not a tracked stack branch (try: git stack parent <parent>)."
  while IFS= read -r b; do
    [[ -n "$b" ]] && printf '%s\t%s\n' "$b" "$(stack_parent "$b")"
  done < <(stack_collect "$cur")
}

sub="${1:-show}"; [[ $# -gt 0 ]] && shift || true
case "$sub" in
  show|"")        cmd_show "$@" ;;
  prs)            cmd_prs "$@" ;;
  list)           cmd_list "$@" ;;
  checkout|co)    cmd_checkout "$@" ;;
  parent)         cmd_parent "$@" ;;
  new)            cmd_new "$@" ;;
  remove)         cmd_remove "$@" ;;
  collapse)       cmd_collapse "$@" ;;
  trunk)          cmd_trunk "$@" ;;
  -h|--help|help) sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//; $d' ;;
  *) die "unknown subcommand: '$sub' (try: git stack --help)" ;;
esac
