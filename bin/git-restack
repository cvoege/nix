#!/usr/bin/env bash
# git-restack — rebase an entire branch stack into one clean linear history.
#
#   trunk <- a <- b <- c   (each branch recorded via `git stack parent`)
#
# Run from ANY branch in the stack. restack will:
#   1. fetch, and fast-forward each branch (and trunk) to its remote when the
#      remote is strictly ahead (adopts review fixups pushed elsewhere);
#   2. rebase every branch onto its parent's new tip, bottom -> top, so each
#      branch contributes only its own commits (no duplication even when a
#      parent diverged, e.g. a review fixup a' landed on `a`);
#   3. force-push (--force-with-lease) every branch in the stack;
#   4. return you to the branch you started on.
#
# Usage:
#   git restack [--no-push] [--offline] [--dry-run]
#   git restack --continue        # resume after resolving a rebase conflict
#   git restack --abort           # undo: restore every branch to its pre-restack tip
#
# Trunk's history is never rewritten or force-pushed.

set -euo pipefail
# shellcheck source=git-stack-lib.sh
source "${GIT_STACK_LIB:-$HOME/.bin/git-stack-lib.sh}"

STATE="$(git rev-parse --git-dir)/stack-restack-state"
TAB=$'\t'

usage() { sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//; $d'; exit "${1:-0}"; }

# ---- state file ----------------------------------------------------------
# Format:
#   ORIG_REF=<branch>
#   PUSH=0|1
#   OFFLINE=0|1
#   IDX=<next plan index to process>
#   --PLAN--
#   <branch>\t<parent>\t<parentBaseSha>\t<branchOrigSha>
#   ...

save_idx() {
  local tmp="$STATE.tmp"
  awk -v idx="$1" 'BEGIN{done=0} /^IDX=/{print "IDX=" idx; done=1; next} {print}' "$STATE" > "$tmp"
  mv "$tmp" "$STATE"
}

load_header() { # key
  grep -m1 "^$1=" "$STATE" | cut -d= -f2-
}

load_plan() { # prints plan lines (after --PLAN--)
  sed -n '/^--PLAN--$/,$p' "$STATE" | tail -n +2
}

clear_state() { rm -f "$STATE"; }

# ---- sync ----------------------------------------------------------------

# Fast-forward a local branch to its remote when the remote is strictly ahead;
# stop hard on genuine divergence. Returns 0 if safe to proceed.
sync_one() { # branch
  local b="$1" r local_sha remote_sha
  r="origin/$b"
  git rev-parse --verify --quiet "refs/remotes/$r" >/dev/null || return 0  # not on remote yet
  local_sha=$(sha "$b"); remote_sha=$(sha "$r")
  [[ "$local_sha" == "$remote_sha" ]] && return 0
  if is_ancestor "$b" "$r"; then
    git update-ref "refs/heads/$b" "$remote_sha"
    info "fast-forwarded $b to origin/$b"
  elif is_ancestor "$r" "$b"; then
    return 0  # local ahead; will be pushed at the end
  else
    die "branch '$b' has diverged from origin/$b (both have unique commits).
   Resolve it manually, or rerun with --offline to skip syncing."
  fi
}

# ---- plan building -------------------------------------------------------

build_plan() { # writes STATE; echoes nothing
  local start trunk orig _ln branches=()
  start=$(current_branch)
  [[ -n "$start" ]] || die "detached HEAD; checkout a stack branch first."
  trunk=$(stack_trunk)

  while IFS= read -r _ln; do branches+=("$_ln"); done < <(stack_collect "$start" || true)
  if [[ ${#branches[@]} -eq 0 || "${branches[0]}" == ERR:* ]]; then
    case "${branches[0]:-}" in
      ERR:on-trunk)  die "you're on trunk ('$trunk'); checkout a stack branch." ;;
      ERR:no-parent:*) die "branch '${branches[0]#ERR:no-parent:}' has no parent.
   Record one with:  git stack parent <parent-branch>" ;;
      ERR:cycle)     die "parent pointers form a cycle." ;;
      *) die "'$start' is not part of a tracked stack. Set its parent:  git stack parent $trunk" ;;
    esac
  fi

  [[ -z "$(git status --porcelain)" ]] || die "working tree is dirty; commit or stash first."

  orig="$start"

  if [[ "$OFFLINE" == 0 ]]; then
    info "fetching origin..."
    git fetch --quiet origin "$trunk" "${branches[@]}" 2>/dev/null || git fetch --quiet origin || true
    sync_one "$trunk"
    local b; for b in "${branches[@]}"; do sync_one "$b"; done
  fi

  # Snapshot parent bases + each branch's original tip (post-sync, pre-rebase).
  {
    echo "ORIG_REF=$orig"
    echo "PUSH=$PUSH"
    echo "OFFLINE=$OFFLINE"
    echo "IDX=0"
    echo "--PLAN--"
    local b parent base orig_sha
    for b in "${branches[@]}"; do
      parent=$(stack_parent "$b")
      base=$(sha "$parent") || die "parent '$parent' of '$b' has no commit."
      orig_sha=$(sha "$b")
      printf '%s\t%s\t%s\t%s\n' "$b" "$parent" "$base" "$orig_sha"
    done
  } > "$STATE"
}

# ---- the rebase loop -----------------------------------------------------

run_loop() {
  local idx n line b parent base _orig _ln
  local -a PLAN
  idx=$(load_header IDX)
  PLAN=()
  while IFS= read -r _ln; do PLAN+=("$_ln"); done < <(load_plan)
  n=${#PLAN[@]}

  while [[ $idx -lt $n ]]; do
    line="${PLAN[$idx]}"
    IFS="$TAB" read -r b parent base _orig <<<"$line"
    info "[$((idx + 1))/$n] rebasing $b onto $parent"
    if ! git rebase --no-update-refs --onto "$parent" "$base" "$b"; then
      cat >&2 <<EOF

git-restack: conflict while rebasing '$b'.
   1. resolve conflicts, then:   git rebase --continue
   2. once that rebase finishes: git restack --continue
   (or abandon everything with:  git restack --abort)
EOF
      exit 1
    fi
    idx=$((idx + 1)); save_idx "$idx"
  done

  finish
}

finish() {
  local push offline orig
  push=$(load_header PUSH); offline=$(load_header OFFLINE); orig=$(load_header ORIG_REF)

  if [[ "$push" == 1 && "$offline" == 0 ]]; then
    local line b _p _b _o
    while IFS= read -r line; do
      IFS="$TAB" read -r b _p _b _o <<<"$line"
      if git rev-parse --verify --quiet "refs/remotes/origin/$b" >/dev/null; then
        info "pushing $b (--force-with-lease)"
        git push --force-with-lease origin "$b"
      else
        info "pushing $b (new, -u)"
        git push -u origin "$b"
      fi
    done < <(load_plan)
  fi

  git checkout --quiet "$orig"
  clear_state
  info "restack complete; back on '$orig'."
}

# ---- continue / abort ----------------------------------------------------

do_continue() {
  [[ -f "$STATE" ]] || die "no restack in progress."
  if rebase_in_progress; then
    if ! git rebase --continue; then
      echo "git-restack: still conflicted; resolve and rerun 'git rebase --continue'." >&2
      exit 1
    fi
    # the in-progress segment just completed; advance past it.
    save_idx "$(( $(load_header IDX) + 1 ))"
  fi
  run_loop
}

do_abort() {
  [[ -f "$STATE" ]] || die "no restack in progress."
  rebase_in_progress && git rebase --abort || true
  local line b _p _base orig
  while IFS= read -r line; do
    IFS="$TAB" read -r b _p _base orig <<<"$line"
    git update-ref "refs/heads/$b" "$orig"
  done < <(load_plan)
  git checkout --quiet "$(load_header ORIG_REF)"
  clear_state
  info "restack aborted; all stack branches restored to their pre-restack tips."
}

dry_run() {
  local line b parent base orig
  echo "would restack (bottom -> top):"
  while IFS= read -r line; do
    IFS="$TAB" read -r b parent base orig <<<"$line"
    printf '  %-24s onto %-20s (base %.10s, tip %.10s)\n' "$b" "$parent" "$base" "$orig"
  done < <(load_plan)
}

# ---- main ----------------------------------------------------------------

PUSH=1; OFFLINE=0; ACTION="run"; DRY=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-push)   PUSH=0 ;;
    --offline)   OFFLINE=1; PUSH=0 ;;
    --dry-run)   DRY=1 ;;
    --continue)  ACTION="continue" ;;
    --abort)     ACTION="abort" ;;
    -h|--help)   usage 0 ;;
    *) die "unknown option: $1 (try --help)" ;;
  esac
  shift
done

case "$ACTION" in
  continue) do_continue ;;
  abort)    do_abort ;;
  run)
    [[ -f "$STATE" ]] && die "a restack is already in progress; use --continue or --abort."
    build_plan
    if [[ "$DRY" == 1 ]]; then dry_run; clear_state; exit 0; fi
    run_loop
    ;;
esac
