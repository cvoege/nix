#!/usr/bin/env bash

set -euxo pipefail

# Where one-shot runs write their durable logs (NOT /tmp — kept around so a
# finished run can be looked up later). Override with CW_LOG_DIR.
CW_LOG_DIR="${CW_LOG_DIR:-$HOME/.cw/logs}"

# cw install
# Prepares a fresh worktree before claude can work in it: installs deps, runs
# doppler setup, and copies in the clasp configs that aren't checked in. Shared
# by both open modes so they never diverge: normal mode runs `cw install` in the
# setup pane, while one-shot calls cw_install directly.
cw_install() {
  pnpm install --frozen-lockfile --prefer-offline || return
  doppler setup --no-interactive || true

  local clasp
  for clasp in gs-addin slides-addin; do
    local src="$HOME/code/monorepo/apps/$clasp/.clasp.json"
    if [ -f "$src" ] ; then
      cp "$src" "apps/$clasp/.clasp.json"
    fi
  done
}

# --- worktree pool ---------------------------------------------------------
# cw keeps a pool of reusable worktrees named cw-worktree-N under
# <repo>-worktrees. An idle ("parked") worktree sits in detached HEAD at trunk;
# a busy one is checked out on a branch. Reusing a parked worktree keeps its
# node_modules and other ignored artifacts around for a fast warm `cw install`.

# _cw_pool_base
# Echo the worktree pool base dir (<repo_parent>/<repo_name>-worktrees),
# derived from the main working tree (first entry of `git worktree list`).
_cw_pool_base() {
  local main_root
  main_root="$(git worktree list | awk 'NR==1{print $1}')" || return 1
  echo "$(dirname "$main_root")/$(basename "$main_root")-worktrees"
}

# _cw_list_parked
# Echo the path of every parked pool worktree, one per line: a worktree whose
# leaf matches cw-worktree-N, that lives under the pool base, and is in detached
# HEAD (no branch). Busy worktrees (on a branch) are skipped.
_cw_list_parked() {
  local base
  base="$(_cw_pool_base)" || return 1
  git worktree list --porcelain | awk -v base="$base" '
    function flush() {
      if (path != "" && detached && !branch) {
        n = split(path, parts, "/"); leaf = parts[n]
        if (leaf ~ /^cw-worktree-[0-9]+$/ && index(path, base "/") == 1) print path
      }
      path = ""; detached = 0; branch = 0
    }
    /^worktree /  { flush(); path = substr($0, 10) }
    /^detached$/  { detached = 1 }
    /^branch /    { branch = 1 }
    END           { flush() }
  '
}

# _cw_find_parked
# Echo the path of the first parked pool worktree, or nothing if none is free.
_cw_find_parked() {
  local all
  all="$(_cw_list_parked)"
  echo "${all%%$'\n'*}"
}

# _cw_next_n
# Echo the next free pool number: one past the highest cw-worktree-N seen among
# both registered worktrees and any leftover dirs under the base.
_cw_next_n() {
  local base leaf n max=0 path
  base="$(_cw_pool_base)" || return 1

  while IFS= read -r path; do
    leaf="${path##*/}"
    if [[ "$leaf" =~ ^cw-worktree-([0-9]+)$ ]]; then
      n="${BASH_REMATCH[1]}"
      if (( n > max )); then max=$n; fi
    fi
  done < <(git worktree list --porcelain | awk '/^worktree /{print substr($0, 10)}')

  if [ -d "$base" ]; then
    for path in "$base"/cw-worktree-*; do
      [ -e "$path" ] || continue
      leaf="${path##*/}"
      if [[ "$leaf" =~ ^cw-worktree-([0-9]+)$ ]]; then
        n="${BASH_REMATCH[1]}"
        if (( n > max )); then max=$n; fi
      fi
    done
  fi

  echo $(( max + 1 ))
}

# _cw_prepare <branch>
# Shared setup for both open modes: computes the tmux window name, acquires a
# pool worktree (reusing a parked one or creating a fresh cw-worktree-N),
# fetches origin, resolves trunk, and points the worktree at <branch>. Sets the
# caller's window/worktree/trunk locals — declare them `local` before calling.
_cw_prepare() {
  local branch="$1"

  # Window name: default to the branch name, but for branches shaped like
  # colton/act-123-whatever, use the ticket id (ACT-123) instead.
  window="$branch"
  if [[ "$branch" =~ ^[a-z]+/([a-z]+-[0-9]+)-.* ]]; then
    window="$(echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
  fi

  # Fetch so we know whether the branch exists on origin, and so we base
  # new branches on the latest trunk.
  git fetch origin --quiet

  # trunk is needed both for basing new branches and for `git stack parent`.
  trunk="$(git stack trunk)"
  if [ -z "$trunk" ]; then
    echo "cw: could not determine origin's default branch" >&2
    return 1
  fi

  # Acquire a worktree from the pool: reuse a parked (detached) one if any,
  # otherwise create a fresh cw-worktree-N detached at trunk.
  worktree="$(_cw_find_parked)"
  if [ -z "$worktree" ]; then
    local base n
    base="$(_cw_pool_base)" || return 1
    n="$(_cw_next_n)" || return 1
    worktree="$base/cw-worktree-$n"
    git worktree add --detach "$worktree" "$trunk" || return 1
  fi

  # Point the acquired worktree at the requested branch. `git switch` reconciles
  # tracked files while leaving ignored artifacts (node_modules, .clasp.json)
  # in place. If the branch is already checked out in another worktree, this
  # fails — same "can't open a branch twice" behavior as before.
  if git show-ref --verify --quiet "refs/heads/$branch" ||
      git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    # Branch already exists: pull it from origin and switch to it.
    git fetch origin "$branch:$branch" 2>/dev/null || git branch -f "$branch" "origin/$branch"
    git -C "$worktree" switch "$branch" || return 1
  else
    # New branch, always based on the latest trunk.
    git -C "$worktree" switch -c "$branch" "$trunk" || return 1
  fi
}

# cw <branch> [prompt]
# Opens a new tmux window running a fresh interactive claude session in a git
# worktree on <branch>, with a second pane for setup. For a headless, logged run
# that tears itself down, see `cw oneshot`.
cw() {
  local branch="${1:-}"
  local prompt="${2:-}"

  if [ -z "$branch" ]; then
    echo "usage: cw <branch> [prompt]" >&2
    return 1
  fi

  local window worktree trunk
  _cw_prepare "$branch" || return 1

  # Open a new tmux window with an empty shell, then type the claude command
  # into it — when claude exits you're back at the shell, so the pane stays. A
  # second pane handles setup.
  local win_id cmd
  win_id="$(tmux new-window -P -F '#{window_id}' -n "$window" -c "$worktree")"
  cmd="claude"
  [ -n "$prompt" ] && cmd="claude --permission-mode auto $(printf '%q' "$prompt")"
  tmux send-keys -t "$win_id.0" "$cmd" Enter
  tmux split-window -v -t "$win_id" -c "$worktree"
  tmux send-keys -t "$win_id.1" "git stack parent '$trunk'" Enter
  tmux send-keys -t "$win_id.1" 'cw install && echo "run cw close to remove this worktree and close the window"' Enter
  tmux select-pane -t "$win_id.0"
}

# cw oneshot <branch> <prompt>
# Headless one-shot: sets up the worktree, then runs setup + `claude -p <prompt>`
# in a single pane, tees all output to a durable log under $CW_LOG_DIR, and tears
# the worktree/window down when claude exits. The pane runs `cw __oneshot`
# (cw_oneshot_run) to do the actual work.
cw_oneshot() {
  local branch="${1:-}"
  local prompt="${2:-}"

  if [ -z "$branch" ]; then
    echo "usage: cw oneshot <branch> <prompt>" >&2
    return 1
  fi
  if [ -z "$prompt" ]; then
    echo "cw: oneshot requires a prompt" >&2
    return 1
  fi

  local window worktree trunk
  _cw_prepare "$branch" || return 1

  mkdir -p "$CW_LOG_DIR"
  # Flatten slashes: branches like chore/foo keep their slash in $window
  # (only ticket-shaped branches get rewritten to ACT-123), and a slash in
  # the filename would point tee at a nonexistent subdir under $CW_LOG_DIR,
  # so it writes nothing.
  local log
  log="$CW_LOG_DIR/${window//\//-}-$(date +%Y%m%d-%H%M%S).log"
  echo "cw: one-shot logging to $log"

  # Ship only a short invocation to the pane; the actual pipeline lives in
  # cw_oneshot_run so it can be written as normal bash. printf %q quotes the
  # args for the trip through the pane's shell.
  # -d: create the window in the background without switching the client to it,
  # so a one-shot run doesn't yank focus away from what you're doing.
  local win_id
  win_id="$(tmux new-window -d -P -F '#{window_id}' -n "$window" -c "$worktree")"
  tmux send-keys -t "$win_id.0" \
    "$(printf 'cw __oneshot %q %q %q %q' "$branch" "$prompt" "$log" "$trunk")" Enter
}

# cw __oneshot <branch> <prompt> <log> <trunk>
# Internal: runs inside the one-shot pane created by `cw oneshot`. Not part of
# the public interface (not in usage()). Runs setup + headless claude, tees all
# output to the durable log, then tears the worktree/window down.
#
# NB: call cw_install / cw_close directly, NOT `cw install` / `cw close`. This
# runs in-process where `cw` resolves to the window-opening shell function, not
# the dispatcher — `cw install` would spawn a stray normal window.
cw_oneshot_run() {
  local branch="$1" prompt="$2" log="$3" trunk="$4"
  local status=0
  {
    git stack parent "$trunk" &&
    echo "Starting $branch" &&
    date &&
    cw_install &&
    echo "Starting claude..." &&
    claude --output-format stream-json --verbose --permission-mode auto -p "$prompt" &&
    echo "Finishing $branch" &&
    date
  } 2>&1 | tee "$log" || status=$?
  # `|| status=$?` does double duty: it stops `set -e` from killing the script
  # the instant claude/setup fails (which would skip the notify + teardown
  # below), and captures the failing exit code. With `pipefail` on and tee
  # effectively never failing, this is the pipeline body's status.
  echo "$status"
  # if [ "$status" -eq 0 ]; then
  #   cnotify -s Glass "$branch finished" "cw one-shot" || true
  # else
  #   cnotify -s Basso "$branch failed (exit $status)" "cw one-shot" || true
  # fi
  cw_close
}

# cw review <branch>
# Code review: opens the worktree + interactive claude running the review.
cw_review() {
  local branch="${1:-}"
  cw "$branch" "/code-review max --comment"
}

# cw review-oneshot <branch>
# One-shot code review: spins up the worktree, runs the review headless, logs
# the output, and tears the worktree/window down when it finishes.
cw_review_oneshot() {
  local branch="${1:-}"
  cw_oneshot "$branch" "/code-review max --comment"
}

# cw close [--remove|-r] [-f|--force]
# Tears down the current cw window and releases its worktree. By default the
# worktree is *parked* (detached at trunk, dir kept with deps) for fast reuse;
# --remove deletes it instead. Legacy branch-named worktrees are always removed.
# Without --force, a worktree with uncommitted/untracked changes refuses, so you
# don't lose work by accident; --force discards those changes.
cw_close() {
  local force="" remove=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--force)  force="--force" ;;
      -r|--remove) remove=1 ;;
    esac
    shift
  done

  local worktree main_root worktrees_base
  worktree="$(git rev-parse --show-toplevel)" || return 1

  # Find the main working tree so we can run git from outside the worktree.
  main_root="$(git worktree list | awk 'NR==1{print $1}')"

  # Only operate on cw worktrees: those living somewhere under <repo>-worktrees,
  # next to the main tree. The first test also refuses to run in the main tree.
  worktrees_base="$(dirname "$main_root")/$(basename "$main_root")-worktrees"
  if [ "$worktree" = "$main_root" ] || [[ "$worktree"/ != "$worktrees_base"/* ]]; then
    echo "cw_close: not inside a cw worktree" >&2
    return 1
  fi

  # Capture the current tmux window before we move away.
  local win_id
  win_id="$(tmux display-message -p '#{window_id}' 2>/dev/null)"

  # Step out of the worktree so operating on its directory is safe.
  cd "$main_root" || return 1

  local leaf="${worktree##*/}"
  if [ -z "$remove" ] && [[ "$leaf" =~ ^cw-worktree-[0-9]+$ ]]; then
    # Park the pool worktree: detach it at trunk so it stays around (with its
    # deps) ready for reuse, releasing whatever branch it was on.
    local trunk
    trunk="$(git -C "$main_root" stack trunk)"
    if [ -z "$trunk" ]; then
      echo "cw_close: could not determine trunk" >&2
      cd "$worktree" 2>/dev/null
      return 1
    fi
    # status --porcelain ignores gitignored files, so node_modules et al. don't
    # count as dirty — only real uncommitted/untracked work blocks a park.
    if [ -n "$(git -C "$worktree" status --porcelain)" ]; then
      if [ -z "$force" ]; then
        echo "cw_close: worktree has uncommitted changes (pass -f to discard, or --remove to delete)" >&2
        cd "$worktree" 2>/dev/null
        return 1
      fi
      # -f: discard tracked changes and untracked files, but keep ignored files
      # (node_modules) so the parked worktree stays warm.
      git -C "$worktree" reset --hard
      git -C "$worktree" clean -fd
    fi
    if ! git -C "$worktree" switch --detach "$trunk"; then
      echo "cw_close: failed to park worktree" >&2
      cd "$worktree" 2>/dev/null
      return 1
    fi
  else
    # Remove entirely: explicit --remove, or a legacy (non-pool) worktree.
    if ! git -C "$main_root" worktree remove $force "$worktree"; then
      echo "cw_close: worktree not removed (pass --force to discard changes)" >&2
      cd "$worktree" 2>/dev/null
      return 1
    fi
  fi

  # Close the tmux window (both panes) if we're inside tmux.
  [ -n "$win_id" ] && tmux kill-window -t "$win_id"
}

# cw clean
# Removes every parked (detached) pool worktree, reclaiming disk. Busy worktrees
# (checked out on a branch) are left untouched. Parked trees are clean, so no
# --force is needed. Runnable from anywhere in the repo.
cw_clean() {
  local main_root path removed=0
  main_root="$(git worktree list | awk 'NR==1{print $1}')"

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    if git -C "$main_root" worktree remove "$path"; then
      removed=$(( removed + 1 ))
      echo "cw clean: removed $path"
    else
      echo "cw clean: could not remove $path" >&2
    fi
  done < <(_cw_list_parked)

  git -C "$main_root" worktree prune
  echo "cw clean: removed $removed parked worktree(s)"
}

usage() {
  cat >&2 <<'EOF'
usage:
  cw <branch> [prompt]            open a worktree + interactive claude in tmux
  cw oneshot <branch> <prompt>    run claude headless, log output, auto-close
  cw review <branch>              open a worktree + interactive code review of <branch>
  cw review-oneshot <branch>      run a code review headless, log output, auto-close
  cw close [--remove] [-f]        park the current cw worktree (reuse later); --remove to delete
  cw clean                        remove all parked (idle) worktrees
  cw install                      prepare the current worktree (deps + configs)
EOF
}

# --- argument dispatch ----------------------------------------------------
# Flags select which action to run; everything else is collected as positional
# args and forwarded to it. Add new flags by extending the case below.
main() {
  local action="cw"
  local -a positional=()

  while [ $# -gt 0 ]; do
    case "$1" in
      oneshot)     action="oneshot" ;;
      close)          action="close" ;;
      clean)          action="clean" ;;
      review)         action="review" ;;
      review-oneshot) action="review-oneshot" ;;
      install)     action="install" ;;
      __oneshot)   action="__oneshot" ;;
      -f|--force)  positional+=("$1") ;;
      -r|--remove) positional+=("$1") ;;
      -h|--help)   usage; return 0 ;;
      --)          shift; while [ $# -gt 0 ]; do positional+=("$1"); shift; done; break ;;
      -*)          echo "cw: unknown option: $1" >&2; usage; return 1 ;;
      *)           positional+=("$1") ;;
    esac
    shift
  done

  case "$action" in
    oneshot)   cw_oneshot ${positional[@]+"${positional[@]}"} ;;
    close)     cw_close ${positional[@]+"${positional[@]}"} ;;
    clean)     cw_clean ;;
    review)    cw_review ${positional[@]+"${positional[@]}"} ;;
    review-oneshot) cw_review_oneshot ${positional[@]+"${positional[@]}"} ;;
    install)   cw_install ;;
    __oneshot) cw_oneshot_run ${positional[@]+"${positional[@]}"} ;;
    cw)        cw ${positional[@]+"${positional[@]}"} ;;
  esac
}

main "$@"
