#!/usr/bin/env bash

set -euo pipefail

# Where one-shot runs write their durable logs (NOT /tmp — kept around so a
# finished run can be looked up later). Override with CW_LOG_DIR.
CW_LOG_DIR="${CW_LOG_DIR:-$HOME/.cw/logs}"

# cw install
# Prepares a fresh worktree before claude can work in it: installs deps, runs
# doppler setup, and copies in the clasp configs that aren't checked in. Shared
# by both open modes so they never diverge: normal mode runs `cw install` in the
# setup pane, while one-shot calls cw_install directly.
cw_install() {
  pnpm install --frozen-lockfile --prefer-offline || return
  doppler setup --no-interactive || true

  local clasp
  for clasp in gs-addin slides-addin; do
    local src="$HOME/code/monorepo/apps/$clasp/.clasp.json"
    if [ -f "$src" ] ; then
      cp "$src" "apps/$clasp/.clasp.json"
    fi
  done
}

# _cw_prepare <branch>
# Shared setup for both open modes: computes the tmux window name and worktree
# path for <branch>, fetches origin, resolves trunk, and creates or checks out
# the worktree. Sets the caller's window/worktree/trunk locals — declare them
# `local` before calling.
_cw_prepare() {
  local branch="$1"

  # Window name: default to the branch name, but for branches shaped like
  # colton/act-123-whatever, use the ticket id (ACT-123) instead.
  window="$branch"
  if [[ "$branch" =~ ^[a-z]+/([a-z]+-[0-9]+)-.* ]]; then
    window="$(echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')"
  fi

  # Resolve worktree location and repo root.
  local repo_root
  repo_root="$(git rev-parse --show-toplevel)" || return 1
  worktree="$repo_root/../$(basename "$repo_root")-worktrees/$window"

  # Fetch so we know whether the branch exists on origin, and so we base
  # new branches on the latest trunk.
  git fetch origin --quiet

  # trunk is needed both for basing new branches and for `git stack parent`.
  trunk="$(git stack trunk)"
  if [ -z "$trunk" ]; then
    echo "cw: could not determine origin's default branch" >&2
    return 1
  fi

  if git show-ref --verify --quiet "refs/heads/$branch" ||
      git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    # Branch already exists: pull it from origin and check it out in the worktree.
    git fetch origin "$branch:$branch" 2>/dev/null || git branch -f "$branch" "origin/$branch"
    git worktree add "$worktree" "$branch" || return 1
  else
    # New branch, always based on the latest trunk.
    git worktree add -b "$branch" "$worktree" "$trunk" || return 1
  fi
}

# cw <branch> [prompt]
# Opens a new tmux window running a fresh interactive claude session in a git
# worktree on <branch>, with a second pane for setup. For a headless, logged run
# that tears itself down, see `cw oneshot`.
cw() {
  local branch="${1:-}"
  local prompt="${2:-}"

  if [ -z "$branch" ]; then
    echo "usage: cw <branch> [prompt]" >&2
    return 1
  fi

  local window worktree trunk
  _cw_prepare "$branch" || return 1

  # Open a new tmux window with an empty shell, then type the claude command
  # into it — when claude exits you're back at the shell, so the pane stays. A
  # second pane handles setup.
  local win_id cmd
  win_id="$(tmux new-window -P -F '#{window_id}' -n "$window" -c "$worktree")"
  cmd="claude"
  [ -n "$prompt" ] && cmd="claude --permission-mode auto $(printf '%q' "$prompt")"
  tmux send-keys -t "$win_id.0" "$cmd" Enter
  tmux split-window -v -t "$win_id" -c "$worktree"
  tmux send-keys -t "$win_id.1" "git stack parent '$trunk'" Enter
  tmux send-keys -t "$win_id.1" 'cw install && echo "run cw close to remove this worktree and close the window"' Enter
  tmux select-pane -t "$win_id.0"
}

# cw oneshot <branch> <prompt>
# Headless one-shot: sets up the worktree, then runs setup + `claude -p <prompt>`
# in a single pane, tees all output to a durable log under $CW_LOG_DIR, and tears
# the worktree/window down when claude exits. The pane runs `cw __oneshot`
# (cw_oneshot_run) to do the actual work.
cw_oneshot() {
  local branch="${1:-}"
  local prompt="${2:-}"

  if [ -z "$branch" ]; then
    echo "usage: cw oneshot <branch> <prompt>" >&2
    return 1
  fi
  if [ -z "$prompt" ]; then
    echo "cw: oneshot requires a prompt" >&2
    return 1
  fi

  local window worktree trunk
  _cw_prepare "$branch" || return 1

  mkdir -p "$CW_LOG_DIR"
  # Flatten slashes: branches like chore/foo keep their slash in $window
  # (only ticket-shaped branches get rewritten to ACT-123), and a slash in
  # the filename would point tee at a nonexistent subdir under $CW_LOG_DIR,
  # so it writes nothing.
  local log
  log="$CW_LOG_DIR/${window//\//-}-$(date +%Y%m%d-%H%M%S).log"
  echo "cw: one-shot logging to $log"

  # Ship only a short invocation to the pane; the actual pipeline lives in
  # cw_oneshot_run so it can be written as normal bash. printf %q quotes the
  # args for the trip through the pane's shell.
  local win_id
  win_id="$(tmux new-window -P -F '#{window_id}' -n "$window" -c "$worktree")"
  tmux send-keys -t "$win_id.0" \
    "$(printf 'cw __oneshot %q %q %q %q' "$branch" "$prompt" "$log" "$trunk")" Enter
}

# cw __oneshot <branch> <prompt> <log> <trunk>
# Internal: runs inside the one-shot pane created by `cw oneshot`. Not part of
# the public interface (not in usage()). Runs setup + headless claude, tees all
# output to the durable log, then tears the worktree/window down.
#
# NB: call cw_install / cw_close directly, NOT `cw install` / `cw close`. This
# runs in-process where `cw` resolves to the window-opening shell function, not
# the dispatcher — `cw install` would spawn a stray normal window.
cw_oneshot_run() {
  local branch="$1" prompt="$2" log="$3" trunk="$4"
  local status=0
  {
    git stack parent "$trunk" &&
    echo "Starting $branch" &&
    date &&
    cw_install &&
    echo "Starting claude..." &&
    claude --output-format stream-json --verbose --permission-mode auto -p "$prompt" &&
    echo "Finishing $branch" &&
    date
  } 2>&1 | tee "$log" || status=$?
  # `|| status=$?` does double duty: it stops `set -e` from killing the script
  # the instant claude/setup fails (which would skip the notify + teardown
  # below), and captures the failing exit code. With `pipefail` on and tee
  # effectively never failing, this is the pipeline body's status.

  if [ "$status" -eq 0 ]; then
    cnotify -s Glass "$branch finished" "cw one-shot" || true
  else
    cnotify -s Basso "$branch failed (exit $status)" "cw one-shot" || true
  fi
  cw_close
}

# cw review <branch>
# One-shot code review: spins up the worktree, runs the review headless, tears down.
cw_review() {
  local branch="${1:-}"
  cw_oneshot "$branch" "/code-review max --comment"
}

# cw close [-f|--force]
# Tears down the current cw worktree: removes the git worktree and closes
# its tmux window (both panes). Run it from inside a cw window.
# Without --force, git refuses if the worktree has uncommitted or untracked
# changes, so you don't lose work by accident.
cw_close() {
  local force=""
  if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--force" ]; then
    force="--force"
  fi

  local worktree main_root worktrees_base
  worktree="$(git rev-parse --show-toplevel)" || return 1

  # Find the main working tree so we can run git from outside the worktree
  # we're about to remove.
  main_root="$(git worktree list | awk 'NR==1{print $1}')"

  # Only operate on cw worktrees: those living somewhere under <repo>-worktrees,
  # next to the main tree. Branch names with slashes (e.g. chore/foo) nest into
  # subdirs, so match anywhere under the base, not just a direct child. The
  # first test also refuses to run in the main tree itself.
  worktrees_base="$(dirname "$main_root")/$(basename "$main_root")-worktrees"
  if [ "$worktree" = "$main_root" ] || [[ "$worktree"/ != "$worktrees_base"/* ]]; then
    echo "cw_close: not inside a cw worktree" >&2
    return 1
  fi

  # Capture the current tmux window before we move away.
  local win_id
  win_id="$(tmux display-message -p '#{window_id}' 2>/dev/null)"

  # Step out of the worktree so removing its directory is safe.
  cd "$main_root" || return 1

  if ! git -C "$main_root" worktree remove $force "$worktree"; then
    echo "cw_close: worktree not removed (pass --force to discard changes)" >&2
    cd "$worktree" 2>/dev/null
    return 1
  fi

  # Close the tmux window (both panes) if we're inside tmux.
  [ -n "$win_id" ] && tmux kill-window -t "$win_id"
}

usage() {
  cat >&2 <<'EOF'
usage:
  cw <branch> [prompt]            open a worktree + interactive claude in tmux
  cw oneshot <branch> <prompt>    run claude headless, log output, auto-close
  cw review <branch>              one-shot code review of <branch>
  cw close [-f|--force]           tear down the current cw worktree + window
  cw install                      prepare the current worktree (deps + configs)
EOF
}

# --- argument dispatch ----------------------------------------------------
# Flags select which action to run; everything else is collected as positional
# args and forwarded to it. Add new flags by extending the case below.
main() {
  local action="cw"
  local -a positional=()

  while [ $# -gt 0 ]; do
    case "$1" in
      oneshot)     action="oneshot" ;;
      close)       action="close" ;;
      review)      action="review" ;;
      install)     action="install" ;;
      __oneshot)   action="__oneshot" ;;
      -f|--force)  positional+=("$1") ;;
      -h|--help)   usage; return 0 ;;
      --)          shift; while [ $# -gt 0 ]; do positional+=("$1"); shift; done; break ;;
      -*)          echo "cw: unknown option: $1" >&2; usage; return 1 ;;
      *)           positional+=("$1") ;;
    esac
    shift
  done

  case "$action" in
    oneshot)   cw_oneshot ${positional[@]+"${positional[@]}"} ;;
    close)     cw_close ${positional[@]+"${positional[@]}"} ;;
    review)    cw_review ${positional[@]+"${positional[@]}"} ;;
    install)   cw_install ;;
    __oneshot) cw_oneshot_run ${positional[@]+"${positional[@]}"} ;;
    cw)        cw ${positional[@]+"${positional[@]}"} ;;
  esac
}

main "$@"
